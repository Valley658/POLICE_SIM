local function radio_message(msg)
    log_event("RADIO", msg)
    if not radio_enabled then return end
    util.toast("[" .. T("Radio") .. "] " .. msg)
    AUDIO.PLAY_SOUND_FRONTEND(-1, "CONFIRM_BEEP", "HUD_MINI_GAME_SOUNDSET", true)
end

local function get_random_pos_around(center, min_dist, max_dist)
    local out = memory.alloc(24)

    -- Try multiple attempts to find a pedestrian-safe position on sidewalks/paths
    for attempt = 1, 5 do
        local angle = math.random() * math.pi * 2
        local dist = min_dist + math.random() * (max_dist - min_dist)
        local x = center.x + math.cos(angle) * dist
        local y = center.y + math.sin(angle) * dist

        if PATHFIND.GET_SAFE_COORD_FOR_PED(x, y, center.z, true, out, 1) then
            local sx = memory.read_float(out)
            local sy = memory.read_float(out + 8)
            local sz = memory.read_float(out + 16)
            return v3(sx, sy, sz)
        end
    end

    -- Fallback: raw ground Z detection
    local angle = math.random() * math.pi * 2
    local dist = min_dist + math.random() * (max_dist - min_dist)
    local x = center.x + math.cos(angle) * dist
    local y = center.y + math.sin(angle) * dist

    local found = memory.alloc(4)
    local z = center.z
    for test_z = 1000.0, 0.0, -50.0 do
        if MISC.GET_GROUND_Z_FOR_3D_COORD(x, y, test_z, found, false, false) then
            z = memory.read_float(found) + 1.0
            break
        end
    end

    return v3(x, y, z)
end

local function safe_delete(handle)
    if handle and handle ~= 0 and ENTITY.DOES_ENTITY_EXIST(handle) then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(handle, true, true)
        entities.delete_by_handle(handle)
    end
end

local function remove_blip(blip)
    if blip and HUD.DOES_BLIP_EXIST(blip) then
        util.remove_blip(blip)
    end
end

local function give_police_weapons(ped)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_pistol"), 200, false, true)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_pumpshotgun"), 50, false, false)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_smg"), 200, false, false)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_stungun"), 100, false, false)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_nightstick"), 1, false, false)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_flashlight"), 1, false, false)
    PED.SET_PED_ARMOUR(ped, 100)
end

local function start_police_mode()
    if police_mode then
        log_event("DUTY", "Attempted to start duty while already on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Already on duty."))
        return
    end

    local model_info = POLICE_MODELS[selected_model_idx]
    local model_hash = util.joaat(model_info.hash)
    log_event("DUTY", "Starting duty | Requesting model: " .. model_info.hash)
    util.request_model(model_hash)

    original_player_ped = players.user_ped()
    local current_pos = players.get_position(players.user())

    local police_ped = PED.CREATE_PED(4, model_hash, current_pos.x, current_pos.y, current_pos.z, ENTITY.GET_ENTITY_HEADING(original_player_ped), true, false)
    if police_ped == 0 then
        log_error("start_police_mode", "Police ped creation failed for model: " .. model_info.hash)
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Police ped creation failed!"))
        original_player_ped = nil
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(police_ped, true, true)
    PED.SET_PED_DEFAULT_COMPONENT_VARIATION(police_ped)
    PED.SET_PED_CONFIG_FLAG(police_ped, 35, false)
    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(original_player_ped, true, true)

    PLAYER.CHANGE_PLAYER_PED(players.user(), police_ped, false, false)
    util.yield(1000)

    -- Preserve custom appearance by stashing original ped underground
    if ENTITY.DOES_ENTITY_EXIST(original_player_ped) then
        ENTITY.SET_ENTITY_COORDS_NO_OFFSET(original_player_ped, original_ped_stash_pos.x, original_ped_stash_pos.y, original_ped_stash_pos.z, false, false, false)
        ENTITY.FREEZE_ENTITY_POSITION(original_player_ped, true)
        ENTITY.SET_ENTITY_COLLISION(original_player_ped, false, false)
        ENTITY.SET_ENTITY_VISIBLE(original_player_ped, false, false)
        ENTITY.SET_ENTITY_INVINCIBLE(original_player_ped, true)
        ENTITY.SET_ENTITY_ALPHA(original_player_ped, 0, false)
        ENTITY.SET_ENTITY_CAN_BE_DAMAGED(original_player_ped, false)
    end

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
    give_police_weapons(players.user_ped())

    if player_invincible then
        menu.set_value(godmode_ref, true)
    end

    police_mode = true
    shift_start_time = os.time()

    log_event("DUTY", "Started duty | Uniform: " .. model_info.name)
    radio_message(T("HQ, on duty. Starting patrol."))
    util.toast("[" .. T("Police Simulator") .. "] " .. T("Police mode activated!") .. "\n" .. T("Uniform") .. ": " .. T(model_info.name))
end

local function stop_police_mode()
    if not police_mode then return end
    local elapsed = os.time() - shift_start_time
    log_event("DUTY", "Ended duty | Time: " .. math.floor(elapsed / 60) .. "min | Arrests: " .. total_arrests .. " | Kills: " .. total_kills .. " | Crimes: " .. total_crimes_detected)

    for _, c in ipairs(criminals) do
        safe_delete(c.ped)
        safe_delete(c.vehicle)
        remove_blip(c.blip)
    end
    criminals = {}

    -- Clean up tactical features
    for _, s in ipairs(spike_strips) do
        safe_delete(s.obj)
        remove_blip(s.blip)
    end
    spike_strips = {}

    for _, b in ipairs(backup_units) do
        safe_delete(b.ped)
        remove_blip(b.blip)
    end
    backup_units = {}

    for _, b in ipairs(bounty_targets) do
        safe_delete(b.ped)
        remove_blip(b.blip)
    end
    bounty_targets = {}

    for _, obj in ipairs(roadblock_objects) do
        safe_delete(obj)
    end
    roadblock_objects = {}

    safe_delete(heli_pilot)
    safe_delete(police_heli)
    heli_pilot = nil
    police_heli = nil

    safe_delete(k9_dog)
    remove_blip(k9_blip)
    k9_dog = nil
    k9_blip = nil

    for _, s in ipairs(swat_team) do
        safe_delete(s.ped)
        remove_blip(s.blip)
    end
    swat_team = {}
    safe_delete(swat_vehicle)
    swat_vehicle = nil

    undercover_mode = false

    speed_trap_active = false
    remove_blip(speed_trap_blip)
    speed_trap_blip = nil
    speed_trap_pos = nil
    speed_trap_fines = 0

    safe_delete(transport_vehicle)
    transport_vehicle = nil
    remove_blip(transport_dest_blip)
    transport_dest_blip = nil
    transport_dest_pos = nil
    transport_active = false
    transport_prisoners = 0

    -- Emergency call cleanup
    safe_delete(emergency_hostage)
    emergency_hostage = nil
    remove_blip(emergency_blip)
    emergency_blip = nil
    emergency_active = false
    emergency_type = nil
    emergency_pos = nil

    -- DUI checkpoint cleanup
    for _, obj in ipairs(dui_checkpoint_objects) do
        safe_delete(obj)
    end
    dui_checkpoint_objects = {}
    remove_blip(dui_checkpoint_blip)
    dui_checkpoint_blip = nil
    dui_checkpoint_active = false
    dui_arrests = 0

    -- Escort mission cleanup
    for _, a in ipairs(escort_attackers) do
        safe_delete(a.ped)
        safe_delete(a.vehicle)
        remove_blip(a.blip)
    end
    escort_attackers = {}
    safe_delete(escort_vip)
    safe_delete(escort_vehicle)
    escort_vip = nil
    escort_vehicle = nil
    remove_blip(escort_dest_blip)
    escort_dest_blip = nil
    escort_dest_pos = nil
    escort_active = false

    -- Police boat cleanup
    safe_delete(police_boat)
    police_boat = nil

    if traffic_stop_target and ENTITY.DOES_ENTITY_EXIST(traffic_stop_target) then
        VEHICLE.SET_VEHICLE_INDICATOR_LIGHTS(traffic_stop_target, 0, false)
        VEHICLE.SET_VEHICLE_INDICATOR_LIGHTS(traffic_stop_target, 1, false)
    end
    traffic_stop_target = nil
    traffic_stop_active = false

    safe_delete(patrol_partner)
    patrol_partner = nil

    chase_active = false
    chase_target = nil

    -- GPS tracking cleanup
    remove_blip(gps_tracking_blip)
    gps_tracking_blip = nil
    gps_tracking_target = nil
    gps_tracking_active = false

    local police_ped = players.user_ped()
    local current_pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(police_ped)

    -- Remove police ped from vehicle before switching to prevent NPC driving
    if PED.IS_PED_IN_ANY_VEHICLE(police_ped, false) then
        local cur_veh = PED.GET_VEHICLE_PED_IS_IN(police_ped, false)
        TASK.CLEAR_PED_TASKS_IMMEDIATELY(police_ped)
        TASK.TASK_LEAVE_VEHICLE(police_ped, cur_veh, 16) -- 16 = teleport out instantly
        util.yield(100)
    end

    -- Freeze police ped to prevent AI actions during transition
    ENTITY.FREEZE_ENTITY_POSITION(police_ped, true)
    PED.SET_PED_CAN_RAGDOLL(police_ped, false)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(police_ped, true)
    TASK.CLEAR_PED_TASKS_IMMEDIATELY(police_ped)

    -- Delete patrol vehicle (police car)
    safe_delete(patrol_vehicle)
    patrol_vehicle = nil

    if original_player_ped and ENTITY.DOES_ENTITY_EXIST(original_player_ped) then
        ENTITY.SET_ENTITY_COORDS_NO_OFFSET(original_player_ped, current_pos.x, current_pos.y, current_pos.z, false, false, false)
        ENTITY.SET_ENTITY_HEADING(original_player_ped, heading)
        ENTITY.SET_ENTITY_VISIBLE(original_player_ped, true, false)
        ENTITY.SET_ENTITY_COLLISION(original_player_ped, true, true)
        ENTITY.FREEZE_ENTITY_POSITION(original_player_ped, false)
        ENTITY.SET_ENTITY_INVINCIBLE(original_player_ped, false)
        ENTITY.SET_ENTITY_CAN_BE_DAMAGED(original_player_ped, true)
        ENTITY.SET_ENTITY_ALPHA(original_player_ped, 255, false)
        ENTITY.SET_ENTITY_HEALTH(original_player_ped, ENTITY.GET_ENTITY_MAX_HEALTH(original_player_ped), 0)

        PLAYER.CHANGE_PLAYER_PED(players.user(), original_player_ped, false, false)
        util.yield(500)

        -- Delete the police ped immediately after switching
        if police_ped ~= players.user_ped() and ENTITY.DOES_ENTITY_EXIST(police_ped) then
            safe_delete(police_ped)
        end
    else
        -- Even if restoration fails, delete the police ped to prevent it from acting
        log_error("stop_police_mode", "Character restoration failed - original_player_ped invalid or missing")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Character restoration failed!") .. "\n" .. T("Reconnect session or use appearance change."))
        if ENTITY.DOES_ENTITY_EXIST(police_ped) then
            safe_delete(police_ped)
        end
    end

    PLAYER.SET_PLAYER_CONTROL(players.user(), true, 0)
    local cur_ped = players.user_ped()
    ENTITY.FREEZE_ENTITY_POSITION(cur_ped, false)
    PED.SET_PED_CAN_RAGDOLL(cur_ped, true)
    ENTITY.SET_ENTITY_VISIBLE(cur_ped, true, false)
    ENTITY.SET_ENTITY_COLLISION(cur_ped, true, true)
    ENTITY.SET_ENTITY_ALPHA(cur_ped, 255, false)

    original_player_ped = nil
    menu.set_value(godmode_ref, original_godmode)

    local elapsed = os.time() - shift_start_time
    local minutes = math.floor(elapsed / 60)

    police_mode = false

    radio_message(T("HQ, ending duty. Good work."))
    util.toast("[" .. T("Police Simulator") .. "] " .. T("Duty ended!") .. "\n" ..
               T("Duty time") .. ": " .. minutes .. T("min") .. "\n" ..
               T("Arrests") .. ": " .. total_arrests .. T("cases") .. "\n" ..
               T("Kills") .. ": " .. total_kills .. T("cases"))
end

local function spawn_partner()
    if not patrol_vehicle or not ENTITY.DOES_ENTITY_EXIST(patrol_vehicle) then return end

    safe_delete(patrol_partner)

    local partner_hash = util.joaat("s_m_y_cop_01")
    util.request_model(partner_hash)

    patrol_partner = PED.CREATE_PED_INSIDE_VEHICLE(patrol_vehicle, 4, partner_hash, 0, true, false)
    if patrol_partner == 0 then
        patrol_partner = nil
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(patrol_partner, true, true)
    ENTITY.SET_ENTITY_INVINCIBLE(patrol_partner, true)
    PED.SET_PED_FLEE_ATTRIBUTES(patrol_partner, 0, false)
    PED.SET_PED_COMBAT_ATTRIBUTES(patrol_partner, 46, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(patrol_partner, 5, true)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(patrol_partner, true)
    PED.SET_PED_CAN_BE_DRAGGED_OUT(patrol_partner, false)

    local pw = PARTNER_WEAPONS[partner_weapon_idx] or PARTNER_WEAPONS[1]
    WEAPON.GIVE_WEAPON_TO_PED(patrol_partner, util.joaat(pw.hash), 200, false, true)
    WEAPON.GIVE_WEAPON_TO_PED(patrol_partner, util.joaat("weapon_pumpshotgun"), 50, false, false)

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(partner_hash)
    log_event("DUTY", "Patrol partner spawned with weapon: " .. pw.hash)
end

local function spawn_patrol_vehicle()
    local veh_info = PATROL_VEHICLES[selected_vehicle_idx]
    local veh_hash = util.joaat(veh_info.hash)
    util.request_model(veh_hash)

    local pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())

    safe_delete(patrol_vehicle)

    local spawn_x = pos.x + math.cos(math.rad(heading)) * 5.0
    local spawn_y = pos.y + math.sin(math.rad(heading)) * 5.0

    patrol_vehicle = VEHICLE.CREATE_VEHICLE(veh_hash, spawn_x, spawn_y, pos.z + 0.5, heading, true, false, false)
    if patrol_vehicle == 0 then
        log_error("spawn_patrol_vehicle", "Vehicle spawn failed for model: " .. veh_info.hash)
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Vehicle spawn failed!"))
        patrol_vehicle = nil
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(patrol_vehicle, true, true)
    VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(patrol_vehicle, 5.0)
    VEHICLE.SET_VEHICLE_ENGINE_ON(patrol_vehicle, true, true, true)
    ENTITY.SET_ENTITY_INVINCIBLE(patrol_vehicle, vehicle_invincible)
    VEHICLE.SET_VEHICLE_SIREN(patrol_vehicle, siren_on)
    VEHICLE.SET_VEHICLE_HAS_MUTED_SIRENS(patrol_vehicle, false)

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(veh_hash)

    if partner_enabled then
        spawn_partner()
    end

    log_event("VEHICLE", "Spawned patrol vehicle: " .. veh_info.name)
    util.toast("[" .. T("Police Simulator") .. "] " .. T("Patrol vehicle spawned") .. ": " .. T(veh_info.name))
end

local function spawn_criminal(pos, armed, has_vehicle)
    if #criminals >= max_criminals then
        log_warning("spawn_criminal", "Max criminals reached (" .. max_criminals .. ")")
        return nil
    end

    local model_hash = util.joaat(CRIMINAL_MODELS[math.random(1, #CRIMINAL_MODELS)])
    util.request_model(model_hash)

    local criminal_ped = PED.CREATE_PED(4, model_hash, pos.x, pos.y, pos.z, math.random(0, 360) * 1.0, true, false)
    if criminal_ped == 0 then
        log_error("spawn_criminal", "Criminal ped creation failed at pos: " .. string.format("%.1f, %.1f, %.1f", pos.x, pos.y, pos.z))
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
        return nil
    end
    log_event("CRIME", "Criminal spawned | Armed: " .. tostring(armed) .. " | Vehicle: " .. tostring(has_vehicle) .. " | Total: " .. (#criminals + 1))

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(criminal_ped, true, true)

    local base_health = ENTITY.GET_ENTITY_MAX_HEALTH(criminal_ped)
    ENTITY.SET_ENTITY_MAX_HEALTH(criminal_ped, math.floor(base_health * criminal_health_mult))
    ENTITY.SET_ENTITY_HEALTH(criminal_ped, math.floor(base_health * criminal_health_mult), 0)

    if armed then
        WEAPON.GIVE_WEAPON_TO_PED(criminal_ped, util.joaat(CRIMINAL_WEAPONS[math.random(1, #CRIMINAL_WEAPONS)]), 200, false, true)
    end

    PED.SET_PED_FLEE_ATTRIBUTES(criminal_ped, 0, false)
    PED.SET_PED_COMBAT_ATTRIBUTES(criminal_ped, 46, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(criminal_ped, 5, true)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(criminal_ped, true)
    PED.SET_PED_ACCURACY(criminal_ped, criminal_accuracy)

    PED.SET_PED_AS_ENEMY(criminal_ped, true)
    TASK.TASK_COMBAT_PED(criminal_ped, players.user_ped(), 0, 16)

    local blip = HUD.ADD_BLIP_FOR_ENTITY(criminal_ped)
    HUD.SET_BLIP_COLOUR(blip, 1)
    HUD.SET_BLIP_SCALE(blip, 0.8)
    HUD.SET_BLIP_AS_SHORT_RANGE(blip, false)

    local criminal_data = {
        ped = criminal_ped,
        blip = blip,
        armed = armed,
        alive = true,
        arrested = false,
        fleeing = false,
        vehicle = nil,
        spawn_time = os.time(),
    }

    if has_vehicle then
        local veh_models = {"sultan", "buffalo", "dominator", "gauntlet", "fugitive", "oracle2", "tailgater", "felon"}
        local veh_hash = util.joaat(veh_models[math.random(1, #veh_models)])
        util.request_model(veh_hash)
        local veh = VEHICLE.CREATE_VEHICLE(veh_hash, pos.x + 3.0, pos.y + 3.0, pos.z, 0.0, true, false, false)
        if veh ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(veh, true, true)
            VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(veh, 5.0)
            PED.SET_PED_INTO_VEHICLE(criminal_ped, veh, -1)
            criminal_data.vehicle = veh
            TASK.TASK_VEHICLE_DRIVE_WANDER(criminal_ped, veh, 80.0, 524852)
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(veh_hash)
    end

    table.insert(criminals, criminal_data)
    total_crimes_detected = total_crimes_detected + 1
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)

    return criminal_data
end

local function arrest_criminal(criminal_data)
    if not criminal_data or criminal_data.arrested then return end
    if not ENTITY.DOES_ENTITY_EXIST(criminal_data.ped) then return end
    if ENTITY.IS_ENTITY_DEAD(criminal_data.ped) then return end

    local player_pos = players.get_position(players.user())
    local crim_pos = ENTITY.GET_ENTITY_COORDS(criminal_data.ped, true)
    local dist = player_pos:distance(crim_pos)

    if dist > arrest_range then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Get closer to the criminal!") .. " (" .. string.format("%.1f", dist) .. "m)")
        return
    end

    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(criminal_data.ped)
    util.yield(200)

    TASK.CLEAR_PED_TASKS_IMMEDIATELY(criminal_data.ped)
    WEAPON.REMOVE_ALL_PED_WEAPONS(criminal_data.ped, true)

    TASK.TASK_PLAY_ANIM(criminal_data.ped, "random@arrests@busted", "idle_a",
        8.0, -8.0, -1, 1, 0, false, false, false)

    util.yield(500)
    ENTITY.FREEZE_ENTITY_POSITION(criminal_data.ped, true)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(criminal_data.ped, true)

    criminal_data.arrested = true
    criminal_data.alive = true
    total_arrests = total_arrests + 1
    add_rank_points(3)

    if criminal_data.blip and HUD.DOES_BLIP_EXIST(criminal_data.blip) then
        HUD.SET_BLIP_COLOUR(criminal_data.blip, 2)
    end

    log_event("ARREST", "Suspect arrested | Total: " .. total_arrests)
    radio_message(T("HQ, 1 suspect arrested. Total arrests") .. ": " .. total_arrests .. T("cases"))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)

    util.yield(3000)
    if ENTITY.DOES_ENTITY_EXIST(criminal_data.ped) then
        for alpha = 240, 0, -30 do
            if not ENTITY.DOES_ENTITY_EXIST(criminal_data.ped) then break end
            ENTITY.SET_ENTITY_ALPHA(criminal_data.ped, alpha, false)
            util.yield(80)
        end
        safe_delete(criminal_data.ped)
    end
    safe_delete(criminal_data.vehicle)
    remove_blip(criminal_data.blip)
end

local function get_closest_criminal()
    local player_pos = players.get_position(players.user())
    local closest = nil
    local closest_dist = 999999.0

    for _, c in ipairs(criminals) do
        if ENTITY.DOES_ENTITY_EXIST(c.ped) and not c.arrested and not ENTITY.IS_ENTITY_DEAD(c.ped) then
            local dist = player_pos:distance(ENTITY.GET_ENTITY_COORDS(c.ped, true))
            if dist < closest_dist then
                closest_dist = dist
                closest = c
            end
        end
    end

    return closest, closest_dist
end

-- ==================== GPS CRIMINAL TRACKING ====================

local gps_tracking_target = nil -- current tracked criminal ped handle

local function update_gps_tracking()
    if not police_mode then return end

    local closest, closest_dist = get_closest_criminal()
    if not closest then
        remove_blip(gps_tracking_blip)
        gps_tracking_blip = nil
        gps_tracking_target = nil
        return
    end

    -- If already tracking this criminal's entity, just ensure route is on
    if gps_tracking_target == closest.ped and gps_tracking_blip and HUD.DOES_BLIP_EXIST(gps_tracking_blip) then
        HUD.SET_BLIP_ROUTE(gps_tracking_blip, true)
        return
    end

    -- Target changed or no blip - create entity-attached blip
    remove_blip(gps_tracking_blip)
    gps_tracking_blip = nil
    gps_tracking_target = closest.ped

    -- Entity blip follows the criminal in real-time
    gps_tracking_blip = HUD.ADD_BLIP_FOR_ENTITY(closest.ped)
    HUD.SET_BLIP_SPRITE(gps_tracking_blip, 458) -- target marker
    HUD.SET_BLIP_COLOUR(gps_tracking_blip, 1)   -- red
    HUD.SET_BLIP_SCALE(gps_tracking_blip, 1.0)
    HUD.SET_BLIP_AS_SHORT_RANGE(gps_tracking_blip, false)
    HUD.SET_BLIP_ROUTE(gps_tracking_blip, true)        -- GPS line on minimap
    HUD.SET_BLIP_ROUTE_COLOUR(gps_tracking_blip, 1)    -- red route
    HUD.SET_BLIP_FLASH_TIMER(gps_tracking_blip, 3000)
    HUD.SET_BLIP_FLASHES(gps_tracking_blip, true)
end

local function start_gps_tracking()
    if not police_mode then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    gps_tracking_active = true
    update_gps_tracking()
    log_event("TRACKING", "GPS criminal tracking activated")
    radio_message(T("GPS tracking activated. Following nearest suspect."))
end

local function stop_gps_tracking()
    gps_tracking_active = false
    remove_blip(gps_tracking_blip)
    gps_tracking_blip = nil
    gps_tracking_target = nil
    log_event("TRACKING", "GPS criminal tracking deactivated")
    radio_message(T("GPS tracking deactivated."))
end

-- GPS tracking tick handler: checks if target changed every 2 seconds
local gps_update_timer = 0
safe_tick_handler("gps_tracking", function()
    if not police_mode or not gps_tracking_active then return end

    -- Check if current target is still valid
    if gps_tracking_target then
        if not ENTITY.DOES_ENTITY_EXIST(gps_tracking_target)
            or ENTITY.IS_ENTITY_DEAD(gps_tracking_target) then
            -- Target gone/dead, force re-acquire
            remove_blip(gps_tracking_blip)
            gps_tracking_blip = nil
            gps_tracking_target = nil
        end
    end

    local now = os.time()
    if now - gps_update_timer < 2 then return end
    gps_update_timer = now

    local closest = get_closest_criminal()
    if not closest then
        remove_blip(gps_tracking_blip)
        gps_tracking_blip = nil
        gps_tracking_target = nil
        return
    end

    -- Re-evaluate: switch to closer criminal if target changed
    if closest.ped ~= gps_tracking_target then
        update_gps_tracking()
    else
        -- Ensure route stays active (GTA can disable it)
        if gps_tracking_blip and HUD.DOES_BLIP_EXIST(gps_tracking_blip) then
            HUD.SET_BLIP_ROUTE(gps_tracking_blip, true)
        end
    end
end)

local function generate_crime_event()
    if not police_mode or #criminals >= max_criminals then return end

    local player_pos = players.get_position(players.user())
    local crime_pos = get_random_pos_around(player_pos, 60.0, crime_radius)

    local armed = math.random() > 0.3
    local has_vehicle = math.random(1, 100) <= criminal_vehicle_chance

    local criminal = spawn_criminal(crime_pos, armed, has_vehicle)
    if criminal then
        log_event("CRIME", CRIME_MESSAGES[math.random(1, #CRIME_MESSAGES)] .. " | Distance: " .. string.format("%.0f", player_pos:distance(crime_pos)) .. "m")
        radio_message(T(CRIME_MESSAGES[math.random(1, #CRIME_MESSAGES)]) .. "\n" .. T("Distance to location") .. ": " ..
                      string.format("%.0f", player_pos:distance(crime_pos)) .. "m")

        if criminal.blip and HUD.DOES_BLIP_EXIST(criminal.blip) then
            HUD.SET_BLIP_FLASHES(criminal.blip, true)
            HUD.SET_BLIP_FLASH_TIMER(criminal.blip, 5000)
        end
    end
end

local function start_chase(criminal_data)
    if not criminal_data or not ENTITY.DOES_ENTITY_EXIST(criminal_data.ped) then return end

    chase_target = criminal_data
    chase_active = true
    log_event("CHASE", "Chase started")

    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(criminal_data.ped)
    util.yield(100)

    if criminal_data.vehicle and ENTITY.DOES_ENTITY_EXIST(criminal_data.vehicle) then
        TASK.CLEAR_PED_TASKS_IMMEDIATELY(criminal_data.ped)
        TASK.TASK_VEHICLE_DRIVE_WANDER(criminal_data.ped, criminal_data.vehicle, 100.0, 524852)
        criminal_data.fleeing = true
        radio_message(T("HQ, suspect fleeing in vehicle! Pursuit started!"))
    else
        TASK.CLEAR_PED_TASKS_IMMEDIATELY(criminal_data.ped)
        TASK.TASK_SMART_FLEE_PED(criminal_data.ped, players.user_ped(), 200.0, -1, false, false)
        criminal_data.fleeing = true
        radio_message(T("HQ, suspect fleeing on foot! Pursuit started!"))
    end

    if patrol_vehicle and ENTITY.DOES_ENTITY_EXIST(patrol_vehicle) then
        VEHICLE.SET_VEHICLE_SIREN(patrol_vehicle, true)
        siren_on = true
    end
end

local function stop_chase()
    log_event("CHASE", "Chase ended")
    chase_active = false
    chase_target = nil
    radio_message(T("Chase ended."))
end

safe_tick_handler("player_protection", function()
    if police_mode and original_player_ped and ENTITY.DOES_ENTITY_EXIST(original_player_ped) then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(original_player_ped, true, true)
        ENTITY.FREEZE_ENTITY_POSITION(original_player_ped, true)
        ENTITY.SET_ENTITY_INVINCIBLE(original_player_ped, true)
        ENTITY.SET_ENTITY_CAN_BE_DAMAGED(original_player_ped, false)
    end

    if police_mode and clear_wanted then
        PLAYER.SET_PLAYER_WANTED_LEVEL(players.user(), 0, false)
        PLAYER.SET_PLAYER_WANTED_LEVEL_NOW(players.user(), false)
    end

    if police_mode and auto_heal then
        local ped = players.user_ped()
        local hp = ENTITY.GET_ENTITY_HEALTH(ped)
        local max_hp = ENTITY.GET_ENTITY_MAX_HEALTH(ped)
        if hp < max_hp and hp > 0 then
            ENTITY.SET_ENTITY_HEALTH(ped, math.min(hp + 1, max_hp), 0)
        end
    end
end)

safe_tick_handler("criminal_tracking", function()
    if not police_mode then return end

    for i = #criminals, 1, -1 do
        local c = criminals[i]
        if ENTITY.DOES_ENTITY_EXIST(c.ped) then
            if ENTITY.IS_ENTITY_DEAD(c.ped) and c.alive and not c.arrested then
                c.alive = false
                total_kills = total_kills + 1
                add_rank_points(1)

                remove_blip(c.blip)
                log_event("KILL", "Suspect killed | Total: " .. total_kills)
                radio_message(T("Suspect killed. Total kills") .. ": " .. total_kills .. T("cases"))

                if chase_target == c then
                    stop_chase()
                end

                local ped_ref = c.ped
                local veh_ref = c.vehicle
                table.remove(criminals, i)

                safe_thread("criminal_cleanup", function()
                    util.yield(3000)
                    safe_delete(ped_ref)
                    safe_delete(veh_ref)
                end)
            end
        else
            remove_blip(c.blip)
            table.remove(criminals, i)
        end
    end

    for i = #criminals, 1, -1 do
        local c = criminals[i]
        if c.arrested and not ENTITY.DOES_ENTITY_EXIST(c.ped) then
            remove_blip(c.blip)
            table.remove(criminals, i)
        end
    end
end)

local last_crime_time = 0
local crime_interval = 30

safe_tick_handler("auto_crime", function()
    if not police_mode or not auto_detect_crime then return end

    local now = os.time()
    if now - last_crime_time >= crime_interval then
        if #criminals < max_criminals and math.random() > 0.4 then
            generate_crime_event()
        end
        last_crime_time = now
    end
end)

safe_tick_handler("partner_follow", function()
    if not police_mode or not patrol_partner then return end
    if not ENTITY.DOES_ENTITY_EXIST(patrol_partner) then
        patrol_partner = nil
        return
    end

    if patrol_vehicle and ENTITY.DOES_ENTITY_EXIST(patrol_vehicle) then
        if PED.IS_PED_IN_VEHICLE(players.user_ped(), patrol_vehicle, false) then
            if not PED.IS_PED_IN_VEHICLE(patrol_partner, patrol_vehicle, false) then
                PED.SET_PED_INTO_VEHICLE(patrol_partner, patrol_vehicle, 0)
            end
        end
    end

    if chase_active and chase_target and ENTITY.DOES_ENTITY_EXIST(chase_target.ped) and not ENTITY.IS_ENTITY_DEAD(chase_target.ped) then
        if PED.GET_SCRIPT_TASK_STATUS(patrol_partner, 0x2E85A751) == 7 then
            TASK.TASK_COMBAT_PED(patrol_partner, chase_target.ped, 0, 16)
        end
    end
end)

local function start_wave_mode()
    if wave_active then
        log_event("WAVE", "Attempted to start wave while already active")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Wave already in progress."))
        return
    end

    wave_active = true
    wave_number = 0
    log_event("WAVE", "Wave mode started")

    radio_message(T("HQ, large-scale criminal activity! Wave mode!"))

    safe_thread("wave_mode", function()
        while wave_active and police_mode do
            wave_number = wave_number + 1
            local num_criminals = math.min(wave_number + 1, max_criminals)

            radio_message(T("Wave") .. " " .. wave_number .. " " .. T("started! Criminals") .. " " .. num_criminals .. T("appeared!"))

            local player_pos = players.get_position(players.user())
            for i = 1, num_criminals do
                if #criminals < max_criminals then
                    spawn_criminal(get_random_pos_around(player_pos, 30.0, 80.0), wave_number >= 2 or math.random() > 0.5, false)
                    util.yield(500)
                end
            end

            while wave_active and police_mode do
                local remaining = 0
                for _, c in ipairs(criminals) do
                    if c.alive and not c.arrested and ENTITY.DOES_ENTITY_EXIST(c.ped) and not ENTITY.IS_ENTITY_DEAD(c.ped) then
                        remaining = remaining + 1
                    end
                end
                if remaining == 0 then break end
                util.yield(1000)
            end

            if not wave_active or not police_mode then break end

            add_rank_points(wave_number * 2)
            radio_message(T("Wave") .. " " .. wave_number .. " " .. T("Wave cleared! Preparing next wave..."))
            AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)
            util.yield(5000)
        end

        wave_active = false
        radio_message(T("Wave mode ended. Total waves") .. ": " .. wave_number)
    end)
end

local function stop_wave_mode()
    log_event("WAVE", "Wave mode stopped | Total waves completed: " .. wave_number)
    wave_active = false
    radio_message(T("Wave mode stopped."))
end

-- ==================== RANK SYSTEM ====================

check_rank_up = function()
    for i = #RANKS, 1, -1 do
        if rank_points >= RANKS[i].points then
            if i > current_rank then
                current_rank = i
                log_event("RANK", "Promoted to " .. RANKS[i].name .. " | Points: " .. rank_points)
                radio_message(T("Promoted!") .. " " .. T("Rank") .. ": " .. T(RANKS[i].name))
                AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)
                util.toast("[" .. T("Police Simulator") .. "] " .. T("Rank Up!") .. "\n" .. T(RANKS[current_rank].name))
            end
            break
        end
    end
end

add_rank_points = function(pts)
    rank_points = rank_points + pts
    check_rank_up()
end

get_rank_name = function()
    return RANKS[current_rank] and T(RANKS[current_rank].name) or T("Cadet")
end

get_next_rank_info = function()
    if current_rank >= #RANKS then return nil, 0 end
    local next = RANKS[current_rank + 1]
    return T(next.name), next.points - rank_points
end

-- ==================== SPIKE STRIP ====================

local function deploy_spike_strip()
    if not police_mode then
        log_warning("deploy_spike_strip", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if #spike_strips >= max_spike_strips then
        log_warning("deploy_spike_strip", "Max spike strips reached (" .. max_spike_strips .. ")")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Max spike strips reached"))
        return
    end

    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())

    local sx = pos.x + fwd.x * 5.0
    local sy = pos.y + fwd.y * 5.0

    local hash = util.joaat("p_ld_stinger_s")
    util.request_model(hash)

    local ground = memory.alloc(4)
    local sz = pos.z
    if MISC.GET_GROUND_Z_FOR_3D_COORD(sx, sy, pos.z + 5.0, ground, false, false) then
        sz = memory.read_float(ground)
    end

    local obj = OBJECT.CREATE_OBJECT(hash, sx, sy, sz, true, false, false)
    if obj ~= 0 then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(obj, true, true)
        place_on_ground(obj)
        ENTITY.SET_ENTITY_HEADING(obj, heading + 90.0)
        ENTITY.FREEZE_ENTITY_POSITION(obj, true)

        local blip = HUD.ADD_BLIP_FOR_COORD(sx, sy, sz)
        HUD.SET_BLIP_SPRITE(blip, 1)
        HUD.SET_BLIP_COLOUR(blip, 5)
        HUD.SET_BLIP_SCALE(blip, 0.5)
        HUD.SET_BLIP_AS_SHORT_RANGE(blip, true)

        table.insert(spike_strips, {obj = obj, blip = blip, x = sx, y = sy, z = sz})
        log_event("TACTICAL", "Spike strip deployed (" .. #spike_strips .. "/" .. max_spike_strips .. ")")
        radio_message(T("Spike strip deployed") .. " (" .. #spike_strips .. "/" .. max_spike_strips .. ")")
    end
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(hash)
end

local function clear_spike_strips()
    log_event("TACTICAL", "All spike strips removed (" .. #spike_strips .. ")")
    for _, s in ipairs(spike_strips) do
        safe_delete(s.obj)
        remove_blip(s.blip)
    end
    spike_strips = {}
    radio_message(T("All spike strips removed"))
end

-- ==================== BACKUP SYSTEM ====================

local function request_backup()
    if not police_mode then
        log_warning("request_backup", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if #backup_units >= max_backup then
        log_warning("request_backup", "Max backup reached (" .. max_backup .. ")")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Max backup reached"))
        return
    end

    local pos = players.get_position(players.user())
    local spawn_pos = get_random_pos_around(pos, 10.0, 25.0)

    local model_hash = util.joaat("s_m_y_cop_01")
    util.request_model(model_hash)

    local ped = PED.CREATE_PED(4, model_hash, spawn_pos.x, spawn_pos.y, spawn_pos.z, 0.0, true, false)
    if ped == 0 then
        log_error("request_backup", "Backup ped creation failed")
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(ped, true, true)
    ENTITY.SET_ENTITY_INVINCIBLE(ped, false)
    PED.SET_PED_ARMOUR(ped, 200)
    ENTITY.SET_ENTITY_MAX_HEALTH(ped, 300)
    ENTITY.SET_ENTITY_HEALTH(ped, 300, 0)

    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_carbinerifle"), 300, false, true)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_pistol"), 200, false, false)

    PED.SET_PED_FLEE_ATTRIBUTES(ped, 0, false)
    PED.SET_PED_COMBAT_ATTRIBUTES(ped, 46, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(ped, 5, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(ped, 0, true)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(ped, true)
    PED.SET_PED_ACCURACY(ped, 60)

    PED.SET_PED_AS_GROUP_MEMBER(ped, PLAYER.GET_PLAYER_GROUP(players.user()))
    PED.SET_PED_RELATIONSHIP_GROUP_HASH(ped, util.joaat("COP"))

    local blip = HUD.ADD_BLIP_FOR_ENTITY(ped)
    HUD.SET_BLIP_COLOUR(blip, 3)
    HUD.SET_BLIP_SCALE(blip, 0.6)
    HUD.SET_BLIP_AS_SHORT_RANGE(blip, true)

    table.insert(backup_units, {ped = ped, blip = blip})
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
    log_event("TACTICAL", "Backup unit arrived (" .. #backup_units .. "/" .. max_backup .. ")")

    radio_message(T("Backup arrived!") .. " (" .. #backup_units .. "/" .. max_backup .. ")")
end

local function dismiss_backup()
    log_event("TACTICAL", "All backup dismissed (" .. #backup_units .. ")")
    for _, b in ipairs(backup_units) do
        safe_delete(b.ped)
        remove_blip(b.blip)
    end
    backup_units = {}
    radio_message(T("All backup dismissed"))
end

-- ==================== POLICE HELICOPTER ====================

local function deploy_helicopter()
    if not police_mode then
        log_warning("deploy_helicopter", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    safe_delete(heli_pilot)
    safe_delete(police_heli)
    heli_pilot = nil
    police_heli = nil

    local pos = players.get_position(players.user())
    local heli_hash = util.joaat("polmav")
    local pilot_hash = util.joaat("s_m_y_hwaycop_01")

    util.request_model(heli_hash)
    util.request_model(pilot_hash)

    police_heli = VEHICLE.CREATE_VEHICLE(heli_hash, pos.x, pos.y, pos.z + 40.0, 0.0, true, false, false)
    if police_heli == 0 then
        police_heli = nil
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(heli_hash)
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(pilot_hash)
        log_error("deploy_helicopter", "Helicopter spawn failed")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Helicopter spawn failed!"))
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(police_heli, true, true)
    ENTITY.SET_ENTITY_INVINCIBLE(police_heli, true)
    VEHICLE.SET_VEHICLE_ENGINE_ON(police_heli, true, true, true)
    VEHICLE.SET_HELI_BLADES_FULL_SPEED(police_heli)
    VEHICLE.SET_VEHICLE_SEARCHLIGHT(police_heli, true, true)

    heli_pilot = PED.CREATE_PED_INSIDE_VEHICLE(police_heli, 4, pilot_hash, -1, true, false)
    if heli_pilot ~= 0 then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(heli_pilot, true, true)
        ENTITY.SET_ENTITY_INVINCIBLE(heli_pilot, true)
        PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(heli_pilot, true)
        TASK.TASK_HELI_MISSION(heli_pilot, police_heli, 0, players.user_ped(), 0.0, 0.0, 0.0, 4, 40.0, 40.0, -1.0, -1, 30, -1.0, 0)
    end

    local blip = HUD.ADD_BLIP_FOR_ENTITY(police_heli)
    HUD.SET_BLIP_SPRITE(blip, 43)
    HUD.SET_BLIP_COLOUR(blip, 3)
    HUD.SET_BLIP_SCALE(blip, 0.8)

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(heli_hash)
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(pilot_hash)

    log_event("TACTICAL", "Helicopter deployed")
    radio_message(T("Air support deployed! Helicopter on station."))
end

local function dismiss_helicopter()
    log_event("TACTICAL", "Helicopter dismissed")
    safe_delete(heli_pilot)
    safe_delete(police_heli)
    heli_pilot = nil
    police_heli = nil
    radio_message(T("Air support dismissed"))
end

-- ==================== FLASHBANG ====================

local function throw_flashbang()
    if not police_mode then
        log_warning("throw_flashbang", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())
    local effect_pos = v3(pos.x + fwd.x * 8.0, pos.y + fwd.y * 8.0, pos.z + 1.0)

    GRAPHICS.ANIMPOSTFX_PLAY("ExplosionJosh3", 1000, false)
    FIRE.ADD_EXPLOSION(effect_pos.x, effect_pos.y, effect_pos.z, 37, 0.0, true, false, 0.5, false)
    AUDIO.PLAY_SOUND_FRONTEND(-1, "TIMER_STOP", "HUD_MINI_GAME_SOUNDSET", true)

    local stunned = 0
    for _, c in ipairs(criminals) do
        if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested then
            local crim_pos = ENTITY.GET_ENTITY_COORDS(c.ped, true)
            if effect_pos:distance(crim_pos) <= 15.0 then
                NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(c.ped)
                TASK.CLEAR_PED_TASKS_IMMEDIATELY(c.ped)
                PED.SET_PED_TO_RAGDOLL(c.ped, 3000, 3000, 0, true, true, false)
                stunned = stunned + 1
            end
        end
    end

    radio_message(T("Flashbang deployed!") .. " " .. stunned .. " " .. T("stunned"))
    log_event("TACTICAL", "Flashbang deployed | Stunned: " .. stunned)

    safe_thread("flashbang_recovery", function()
        util.yield(3000)
        for _, c in ipairs(criminals) do
            if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested and not ENTITY.IS_ENTITY_DEAD(c.ped) then
                TASK.TASK_COMBAT_PED(c.ped, players.user_ped(), 0, 16)
            end
        end
    end)
end

-- ==================== TRAFFIC STOP ====================

local function initiate_traffic_stop()
    if not police_mode then
        log_warning("initiate_traffic_stop", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local ped = players.user_ped()
    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(ped)

    local best_veh = nil
    local best_dist = 50.0

    for _, veh in ipairs(entities.get_all_vehicles_as_handles()) do
        if ENTITY.DOES_ENTITY_EXIST(veh) and not PED.IS_PED_IN_VEHICLE(ped, veh, false) then
            local veh_pos = ENTITY.GET_ENTITY_COORDS(veh, true)
            local dx = veh_pos.x - pos.x
            local dy = veh_pos.y - pos.y
            local dist = math.sqrt(dx * dx + dy * dy)
            if dist <= best_dist and dist > 0 then
                local dot = (dx / dist) * fwd.x + (dy / dist) * fwd.y
                if dot > 0.5 then
                    best_dist = dist
                    best_veh = veh
                end
            end
        end
    end

    if not best_veh then
        log_event("TRAFFIC", "Traffic stop failed - no vehicle ahead")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No vehicle ahead"))
        return
    end

    traffic_stop_target = best_veh
    traffic_stop_active = true

    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(best_veh)
    util.yield(200)

    VEHICLE.SET_VEHICLE_INDICATOR_LIGHTS(best_veh, 0, true)
    VEHICLE.SET_VEHICLE_INDICATOR_LIGHTS(best_veh, 1, true)
    VEHICLE.SET_VEHICLE_FORWARD_SPEED(best_veh, 0.0)

    local driver = VEHICLE.GET_PED_IN_VEHICLE_SEAT(best_veh, -1, false)
    if driver ~= 0 then
        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(driver)
        TASK.CLEAR_PED_TASKS_IMMEDIATELY(driver)
        TASK.TASK_VEHICLE_TEMP_ACTION(driver, best_veh, 1, 5000)
    end

    if patrol_vehicle and ENTITY.DOES_ENTITY_EXIST(patrol_vehicle) then
        VEHICLE.SET_VEHICLE_SIREN(patrol_vehicle, true)
        siren_on = true
    end

    local blip = HUD.ADD_BLIP_FOR_ENTITY(best_veh)
    HUD.SET_BLIP_COLOUR(blip, 5)
    HUD.SET_BLIP_SCALE(blip, 0.7)

    radio_message(T("Traffic stop initiated"))
    log_event("TRAFFIC", "Traffic stop initiated")
end

local function order_driver_out()
    if not traffic_stop_active or not traffic_stop_target then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No active traffic stop"))
        return
    end

    if not ENTITY.DOES_ENTITY_EXIST(traffic_stop_target) then
        traffic_stop_active = false
        traffic_stop_target = nil
        return
    end

    local driver = VEHICLE.GET_PED_IN_VEHICLE_SEAT(traffic_stop_target, -1, false)
    if driver ~= 0 then
        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(driver)
        TASK.TASK_LEAVE_VEHICLE(driver, traffic_stop_target, 0)
        safe_thread("traffic_stop_handsup", function()
            util.yield(3000)
            if ENTITY.DOES_ENTITY_EXIST(driver) and not PED.IS_PED_IN_ANY_VEHICLE(driver, false) then
                TASK.TASK_HANDS_UP(driver, 10000, players.user_ped(), -1, false)
            end
        end)
    end

    log_event("TRAFFIC", "Driver ordered out of vehicle")
    radio_message(T("Driver ordered out of vehicle"))
end

local function end_traffic_stop()
    if traffic_stop_target and ENTITY.DOES_ENTITY_EXIST(traffic_stop_target) then
        local driver = VEHICLE.GET_PED_IN_VEHICLE_SEAT(traffic_stop_target, -1, false)
        if driver ~= 0 then
            NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(driver)
            TASK.CLEAR_PED_TASKS_IMMEDIATELY(driver)
        end
        VEHICLE.SET_VEHICLE_INDICATOR_LIGHTS(traffic_stop_target, 0, false)
        VEHICLE.SET_VEHICLE_INDICATOR_LIGHTS(traffic_stop_target, 1, false)
    end
    traffic_stop_target = nil
    traffic_stop_active = false
    log_event("TRAFFIC", "Traffic stop ended")
    radio_message(T("Traffic stop ended"))
end

-- ==================== ROADBLOCK ====================

local function deploy_roadblock()
    if not police_mode then
        log_warning("deploy_roadblock", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())

    local base_x = pos.x + fwd.x * 15.0
    local base_y = pos.y + fwd.y * 15.0
    local base_z = pos.z

    local ground = memory.alloc(4)
    if MISC.GET_GROUND_Z_FOR_3D_COORD(base_x, base_y, base_z + 10.0, ground, false, false) then
        base_z = memory.read_float(ground)
    end

    local right_x = -fwd.y
    local right_y = fwd.x

    -- Police vehicles as roadblock
    for i = -1, 1, 2 do
        local veh_hash = util.joaat("police")
        util.request_model(veh_hash)
        local ox = base_x + right_x * (i * 4.0)
        local oy = base_y + right_y * (i * 4.0)
        local veh = VEHICLE.CREATE_VEHICLE(veh_hash, ox, oy, base_z, heading + 45.0 * i, true, false, false)
        if veh ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(veh, true, true)
            VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(veh, 5.0)
            ENTITY.FREEZE_ENTITY_POSITION(veh, true)
            ENTITY.SET_ENTITY_INVINCIBLE(veh, true)
            VEHICLE.SET_VEHICLE_SIREN(veh, true)
            table.insert(roadblock_objects, veh)
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(veh_hash)
    end

    -- Barriers
    for i = -2, 2 do
        local hash = util.joaat("prop_barrier_work05")
        util.request_model(hash)
        local ox = base_x + right_x * (i * 2.5)
        local oy = base_y + right_y * (i * 2.5)
        local obj = OBJECT.CREATE_OBJECT(hash, ox, oy, base_z, true, false, false)
        if obj ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(obj, true, true)
            place_on_ground(obj)
            ENTITY.SET_ENTITY_HEADING(obj, heading + 90.0)
            ENTITY.FREEZE_ENTITY_POSITION(obj, true)
            table.insert(roadblock_objects, obj)
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(hash)
    end

    -- Cones
    for i = -1, 1, 2 do
        local hash = util.joaat("prop_roadcone01a")
        util.request_model(hash)
        local ox = base_x + right_x * (i * 7.0)
        local oy = base_y + right_y * (i * 7.0)
        local obj = OBJECT.CREATE_OBJECT(hash, ox, oy, base_z, true, false, false)
        if obj ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(obj, true, true)
            place_on_ground(obj)
            ENTITY.FREEZE_ENTITY_POSITION(obj, true)
            table.insert(roadblock_objects, obj)
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(hash)
    end

    radio_message(T("Roadblock deployed"))
    log_event("TACTICAL", "Roadblock deployed")
end

local function clear_roadblocks()
    log_event("TACTICAL", "All roadblocks cleared (" .. #roadblock_objects .. " objects)")
    for _, obj in ipairs(roadblock_objects) do
        safe_delete(obj)
    end
    roadblock_objects = {}
    radio_message(T("All roadblocks cleared"))
end

-- ==================== BOUNTY BOARD ====================

local function generate_bounty()
    if not police_mode then
        log_warning("generate_bounty", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if #bounty_targets >= max_bounties then
        log_warning("generate_bounty", "Max bounties reached (" .. max_bounties .. ")")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Max bounties reached"))
        return
    end

    local pos = players.get_position(players.user())
    local target_pos = get_random_pos_around(pos, 80.0, 200.0)

    local model_hash = util.joaat(CRIMINAL_MODELS[math.random(1, #CRIMINAL_MODELS)])
    util.request_model(model_hash)

    local ped = PED.CREATE_PED(4, model_hash, target_pos.x, target_pos.y, target_pos.z, math.random(0, 360) * 1.0, true, false)
    if ped == 0 then
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(ped, true, true)

    local base_hp = ENTITY.GET_ENTITY_MAX_HEALTH(ped)
    ENTITY.SET_ENTITY_MAX_HEALTH(ped, base_hp * 3)
    ENTITY.SET_ENTITY_HEALTH(ped, base_hp * 3, 0)
    PED.SET_PED_ARMOUR(ped, 100)

    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_assaultrifle"), 500, false, true)
    WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_rpg"), 5, false, false)

    PED.SET_PED_FLEE_ATTRIBUTES(ped, 0, false)
    PED.SET_PED_COMBAT_ATTRIBUTES(ped, 46, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(ped, 5, true)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(ped, true)
    PED.SET_PED_ACCURACY(ped, 50)
    PED.SET_PED_AS_ENEMY(ped, true)
    TASK.TASK_COMBAT_PED(ped, players.user_ped(), 0, 16)

    local blip = HUD.ADD_BLIP_FOR_ENTITY(ped)
    HUD.SET_BLIP_SPRITE(blip, 303)
    HUD.SET_BLIP_COLOUR(blip, 6)
    HUD.SET_BLIP_SCALE(blip, 1.0)
    HUD.SET_BLIP_AS_SHORT_RANGE(blip, false)
    HUD.SET_BLIP_FLASHES(blip, true)
    HUD.SET_BLIP_FLASH_TIMER(blip, 5000)

    local bounty_name = T("Most Wanted") .. " #" .. (#bounty_targets + 1)
    local bounty_reward = 5 + math.random(1, 5)

    table.insert(bounty_targets, {
        ped = ped,
        blip = blip,
        name = bounty_name,
        reward = bounty_reward,
        alive = true,
    })

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)
    log_event("BOUNTY", "Bounty generated: " .. bounty_name .. " | Reward: +" .. bounty_reward .. " pts")
    radio_message(bounty_name .. " " .. T("spotted!") .. " " .. T("Reward") .. ": +" .. bounty_reward .. " " .. T("pts"))
end

local function clear_bounties()
    log_event("BOUNTY", "All bounties cleared (" .. #bounty_targets .. ")")
    for _, b in ipairs(bounty_targets) do
        safe_delete(b.ped)
        remove_blip(b.blip)
    end
    bounty_targets = {}
    radio_message(T("All bounties cleared"))
end

-- ==================== WARNING SHOT ====================

local function fire_warning_shot()
    if not police_mode then
        log_warning("fire_warning_shot", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local pos = players.get_position(players.user())
    MISC.SHOOT_SINGLE_BULLET_BETWEEN_COORDS(
        pos.x, pos.y, pos.z + 1.5,
        pos.x, pos.y, pos.z + 50.0,
        0, false, util.joaat("weapon_pistol"), players.user_ped(), true, true, 300.0
    )

    AUDIO.PLAY_SOUND_FRONTEND(-1, "CONFIRM_BEEP", "HUD_MINI_GAME_SOUNDSET", true)

    local scared = 0
    for _, c in ipairs(criminals) do
        if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested then
            local crim_pos = ENTITY.GET_ENTITY_COORDS(c.ped, true)
            if pos:distance(crim_pos) <= 30.0 then
                if math.random(1, 100) <= criminal_flee_chance then
                    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(c.ped)
                    TASK.CLEAR_PED_TASKS_IMMEDIATELY(c.ped)
                    TASK.TASK_SMART_FLEE_PED(c.ped, players.user_ped(), 100.0, -1, false, false)
                    c.fleeing = true
                    scared = scared + 1
                end
            end
        end
    end

    radio_message(T("Warning shot fired!") .. (scared > 0 and (" " .. scared .. " " .. T("fled")) or ""))
    log_event("TACTICAL", "Warning shot fired | Fled: " .. scared)
end

-- ==================== K9 UNIT ====================

local function deploy_k9()
    if not police_mode then
        log_warning("deploy_k9", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    safe_delete(k9_dog)
    remove_blip(k9_blip)
    k9_dog = nil
    k9_blip = nil

    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())

    local dog_hash = util.joaat("a_c_shepherd")
    util.request_model(dog_hash)

    k9_dog = PED.CREATE_PED(28, dog_hash, pos.x + fwd.x * 3.0, pos.y + fwd.y * 3.0, pos.z, ENTITY.GET_ENTITY_HEADING(players.user_ped()), true, false)
    if k9_dog == 0 then
        k9_dog = nil
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(dog_hash)
        log_error("deploy_k9", "K9 spawn failed")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("K9 spawn failed!"))
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(k9_dog, true, true)
    ENTITY.SET_ENTITY_INVINCIBLE(k9_dog, true)
    PED.SET_PED_FLEE_ATTRIBUTES(k9_dog, 0, false)
    PED.SET_PED_COMBAT_ATTRIBUTES(k9_dog, 46, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(k9_dog, 5, true)
    PED.SET_PED_COMBAT_ATTRIBUTES(k9_dog, 0, true)
    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(k9_dog, true)
    PED.SET_PED_COMBAT_ABILITY(k9_dog, 2)

    PED.SET_PED_AS_GROUP_MEMBER(k9_dog, PLAYER.GET_PLAYER_GROUP(players.user()))
    PED.SET_PED_RELATIONSHIP_GROUP_HASH(k9_dog, util.joaat("COP"))

    k9_blip = HUD.ADD_BLIP_FOR_ENTITY(k9_dog)
    HUD.SET_BLIP_SPRITE(k9_blip, 1)
    HUD.SET_BLIP_COLOUR(k9_blip, 11)
    HUD.SET_BLIP_SCALE(k9_blip, 0.5)
    HUD.SET_BLIP_AS_SHORT_RANGE(k9_blip, true)

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(dog_hash)
    log_event("K9", "K9 unit deployed")
    radio_message(T("K9 unit deployed!"))
end

local function dismiss_k9()
    log_event("K9", "K9 unit dismissed")
    safe_delete(k9_dog)
    remove_blip(k9_blip)
    k9_dog = nil
    k9_blip = nil
    radio_message(T("K9 unit dismissed"))
end

local function k9_attack_nearest()
    if not k9_dog or not ENTITY.DOES_ENTITY_EXIST(k9_dog) then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No K9 unit deployed"))
        return
    end

    local closest = get_closest_criminal()
    if not closest then
        -- Also check bounty targets
        local nearest_dist = 999999.0
        local nearest_ped = nil
        local dog_pos = ENTITY.GET_ENTITY_COORDS(k9_dog, true)
        for _, b in ipairs(bounty_targets) do
            if ENTITY.DOES_ENTITY_EXIST(b.ped) and b.alive and not ENTITY.IS_ENTITY_DEAD(b.ped) then
                local dist = dog_pos:distance(ENTITY.GET_ENTITY_COORDS(b.ped, true))
                if dist < nearest_dist then
                    nearest_dist = dist
                    nearest_ped = b.ped
                end
            end
        end
        if nearest_ped then
            NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(k9_dog)
            TASK.TASK_COMBAT_PED(k9_dog, nearest_ped, 0, 16)
            log_event("K9", "K9 attacking suspect")
            radio_message(T("K9 attacking suspect!"))
            return
        end
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No criminals nearby."))
        return
    end

    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(k9_dog)
    TASK.TASK_COMBAT_PED(k9_dog, closest.ped, 0, 16)
    log_event("K9", "K9 attacking criminal")
    radio_message(T("K9 attacking suspect!"))
end

local function k9_follow()
    if not k9_dog or not ENTITY.DOES_ENTITY_EXIST(k9_dog) then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No K9 unit deployed"))
        return
    end
    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(k9_dog)
    TASK.CLEAR_PED_TASKS_IMMEDIATELY(k9_dog)
    TASK.TASK_FOLLOW_TO_OFFSET_OF_ENTITY(k9_dog, players.user_ped(), 0.0, -1.5, 0.0, 5.0, -1, 2.0, true)
    log_event("K9", "K9 set to follow")
    radio_message(T("K9 following"))
end

-- ==================== SWAT RAID ====================

local function call_swat()
    if not police_mode then
        log_warning("call_swat", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if #swat_team >= max_swat then
        log_warning("call_swat", "SWAT team already deployed")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("SWAT team already deployed"))
        return
    end

    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())

    -- Spawn SWAT van
    local van_hash = util.joaat("riot")
    util.request_model(van_hash)
    local van_pos = v3(pos.x - fwd.x * 20.0, pos.y - fwd.y * 20.0, pos.z)

    local ground = memory.alloc(4)
    if MISC.GET_GROUND_Z_FOR_3D_COORD(van_pos.x, van_pos.y, van_pos.z + 10.0, ground, false, false) then
        van_pos.z = memory.read_float(ground)
    end

    safe_delete(swat_vehicle)
    swat_vehicle = VEHICLE.CREATE_VEHICLE(van_hash, van_pos.x, van_pos.y, van_pos.z + 0.5, ENTITY.GET_ENTITY_HEADING(players.user_ped()) + 180.0, true, false, false)
    if swat_vehicle ~= 0 then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(swat_vehicle, true, true)
        VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(swat_vehicle, 5.0)
        ENTITY.SET_ENTITY_INVINCIBLE(swat_vehicle, true)
        VEHICLE.SET_VEHICLE_SIREN(swat_vehicle, true)
    end
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(van_hash)

    -- Spawn SWAT members
    local swat_hash = util.joaat("s_m_y_swat_01")
    util.request_model(swat_hash)

    local swat_weapons = {"weapon_carbinerifle", "weapon_smg", "weapon_pumpshotgun", "weapon_assaultshotgun", "weapon_specialcarbine"}

    for i = 1, max_swat do
        local angle = (i / max_swat) * math.pi * 2
        local sx = pos.x + math.cos(angle) * 8.0
        local sy = pos.y + math.sin(angle) * 8.0

        local ped = PED.CREATE_PED(4, swat_hash, sx, sy, pos.z, 0.0, true, false)
        if ped ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(ped, true, true)
            ENTITY.SET_ENTITY_INVINCIBLE(ped, false)
            PED.SET_PED_ARMOUR(ped, 300)
            ENTITY.SET_ENTITY_MAX_HEALTH(ped, 400)
            ENTITY.SET_ENTITY_HEALTH(ped, 400, 0)

            local wpn = swat_weapons[math.random(1, #swat_weapons)]
            WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat(wpn), 500, false, true)
            WEAPON.GIVE_WEAPON_TO_PED(ped, util.joaat("weapon_pistol"), 200, false, false)

            PED.SET_PED_FLEE_ATTRIBUTES(ped, 0, false)
            PED.SET_PED_COMBAT_ATTRIBUTES(ped, 46, true)
            PED.SET_PED_COMBAT_ATTRIBUTES(ped, 5, true)
            PED.SET_PED_COMBAT_ATTRIBUTES(ped, 0, true)
            PED.SET_PED_COMBAT_ATTRIBUTES(ped, 2, true)
            PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(ped, true)
            PED.SET_PED_ACCURACY(ped, 70)
            PED.SET_PED_COMBAT_ABILITY(ped, 2)

            PED.SET_PED_AS_GROUP_MEMBER(ped, PLAYER.GET_PLAYER_GROUP(players.user()))
            PED.SET_PED_RELATIONSHIP_GROUP_HASH(ped, util.joaat("COP"))

            local blip = HUD.ADD_BLIP_FOR_ENTITY(ped)
            HUD.SET_BLIP_COLOUR(blip, 38)
            HUD.SET_BLIP_SCALE(blip, 0.5)
            HUD.SET_BLIP_AS_SHORT_RANGE(blip, true)

            table.insert(swat_team, {ped = ped, blip = blip})
        end
    end

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(swat_hash)
    log_event("SWAT", "SWAT team deployed | Members: " .. #swat_team)
    radio_message(T("SWAT team deployed!") .. " " .. #swat_team .. " " .. T("operators on site"))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "CONFIRM_BEEP", "HUD_MINI_GAME_SOUNDSET", true)
    add_rank_points(2)
end

local function dismiss_swat()
    log_event("SWAT", "SWAT team dismissed (" .. #swat_team .. " members)")
    for _, s in ipairs(swat_team) do
        safe_delete(s.ped)
        remove_blip(s.blip)
    end
    swat_team = {}
    safe_delete(swat_vehicle)
    swat_vehicle = nil
    radio_message(T("SWAT team dismissed"))
end

-- ==================== UNDERCOVER MODE ====================

local UNDERCOVER_MODELS = {
    "a_m_y_business_01", "a_m_y_hipster_01", "a_m_y_soucent_01",
    "a_m_y_vinewood_01", "a_m_y_downtown_01", "a_f_y_business_01",
}

local UNDERCOVER_VEHICLES = {
    "sultan", "buffalo", "oracle2", "tailgater", "felon", "schafter2",
}

local function toggle_undercover()
    if not police_mode then
        log_warning("toggle_undercover", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    if undercover_mode then
        log_event("UNDERCOVER", "Switching back to police uniform")
        -- Switch back to police uniform
        local model_info = POLICE_MODELS[selected_model_idx]
        local model_hash = util.joaat(model_info.hash)
        util.request_model(model_hash)

        local cur_ped = players.user_ped()
        local cur_pos = players.get_position(players.user())
        local heading = ENTITY.GET_ENTITY_HEADING(cur_ped)

        local new_ped = PED.CREATE_PED(4, model_hash, cur_pos.x, cur_pos.y, cur_pos.z, heading, true, false)
        if new_ped ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(new_ped, true, true)
            PED.SET_PED_DEFAULT_COMPONENT_VARIATION(new_ped)
            PED.SET_PED_CONFIG_FLAG(new_ped, 35, false)
            PLAYER.CHANGE_PLAYER_PED(players.user(), new_ped, false, false)
            util.yield(500)

            if cur_ped ~= players.user_ped() and ENTITY.DOES_ENTITY_EXIST(cur_ped) then
                safe_delete(cur_ped)
            end
            give_police_weapons(players.user_ped())
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)

        undercover_mode = false
        log_event("UNDERCOVER", "Undercover mode deactivated")
        radio_message(T("Back in uniform. Undercover mode off."))
    else
        -- Switch to civilian
        log_event("UNDERCOVER", "Switching to undercover mode")
        local civ_model = UNDERCOVER_MODELS[math.random(1, #UNDERCOVER_MODELS)]
        local model_hash = util.joaat(civ_model)
        util.request_model(model_hash)

        local cur_ped = players.user_ped()
        local cur_pos = players.get_position(players.user())
        local heading = ENTITY.GET_ENTITY_HEADING(cur_ped)

        local new_ped = PED.CREATE_PED(4, model_hash, cur_pos.x, cur_pos.y, cur_pos.z, heading, true, false)
        if new_ped ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(new_ped, true, true)
            PED.SET_PED_DEFAULT_COMPONENT_VARIATION(new_ped)
            PED.SET_PED_CONFIG_FLAG(new_ped, 35, false)
            PLAYER.CHANGE_PLAYER_PED(players.user(), new_ped, false, false)
            util.yield(500)

            if cur_ped ~= players.user_ped() and ENTITY.DOES_ENTITY_EXIST(cur_ped) then
                safe_delete(cur_ped)
            end
            -- Give concealed weapons only
            WEAPON.GIVE_WEAPON_TO_PED(players.user_ped(), util.joaat("weapon_snspistol"), 100, false, true)
            WEAPON.GIVE_WEAPON_TO_PED(players.user_ped(), util.joaat("weapon_switchblade"), 1, false, false)
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model_hash)

        undercover_mode = true
        log_event("UNDERCOVER", "Undercover mode activated")
        radio_message(T("Undercover mode activated. Blend in."))
    end
end

local function spawn_undercover_vehicle()
    if not police_mode then
        log_warning("spawn_undercover_vehicle", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local veh_model = UNDERCOVER_VEHICLES[math.random(1, #UNDERCOVER_VEHICLES)]
    local veh_hash = util.joaat(veh_model)
    util.request_model(veh_hash)

    local pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())
    local spawn_x = pos.x + math.cos(math.rad(heading)) * 5.0
    local spawn_y = pos.y + math.sin(math.rad(heading)) * 5.0

    local veh = VEHICLE.CREATE_VEHICLE(veh_hash, spawn_x, spawn_y, pos.z + 0.5, heading, true, false, false)
    if veh ~= 0 then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(veh, true, true)
        VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(veh, 5.0)
        VEHICLE.SET_VEHICLE_ENGINE_ON(veh, true, true, true)
        VEHICLE.SET_VEHICLE_MOD_KIT(veh, 0)
        -- Random color
        local r, g, b = math.random(0, 255), math.random(0, 255), math.random(0, 255)
        VEHICLE.SET_VEHICLE_CUSTOM_PRIMARY_COLOUR(veh, r, g, b)
        VEHICLE.SET_VEHICLE_CUSTOM_SECONDARY_COLOUR(veh, r, g, b)
        -- Tinted windows
        VEHICLE.SET_VEHICLE_WINDOW_TINT(veh, 1)
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Undercover vehicle spawned"))
        log_event("UNDERCOVER", "Undercover vehicle spawned: " .. veh_model)
    end
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(veh_hash)
end

-- ==================== SMOKE GRENADE ====================

local function throw_smoke_grenade()
    if not police_mode then
        log_warning("throw_smoke_grenade", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local pos = players.get_position(players.user())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())
    local effect_pos = v3(pos.x + fwd.x * 10.0, pos.y + fwd.y * 10.0, pos.z)

    -- Use PTFX for smoke
    GRAPHICS.REQUEST_NAMED_PTFX_ASSET("core")
    local attempts = 0
    while not GRAPHICS.HAS_NAMED_PTFX_ASSET_LOADED("core") and attempts < 50 do
        util.yield(10)
        attempts = attempts + 1
    end

    GRAPHICS.USE_PARTICLE_FX_ASSET("core")
    GRAPHICS.START_NETWORKED_PARTICLE_FX_NON_LOOPED_AT_COORD(
        "exp_grd_smoke_thin", effect_pos.x, effect_pos.y, effect_pos.z,
        0.0, 0.0, 0.0, 3.0, false, false, false, false
    )

    -- Additional smoke puffs
    for i = 1, 5 do
        util.yield(200)
        local ox = effect_pos.x + math.random(-3, 3) * 1.0
        local oy = effect_pos.y + math.random(-3, 3) * 1.0
        GRAPHICS.USE_PARTICLE_FX_ASSET("core")
        GRAPHICS.START_NETWORKED_PARTICLE_FX_NON_LOOPED_AT_COORD(
            "exp_grd_smoke_thin", ox, oy, effect_pos.z,
            0.0, 0.0, 0.0, 2.0, false, false, false, false
        )
    end

    AUDIO.PLAY_SOUND_FRONTEND(-1, "CONFIRM_BEEP", "HUD_MINI_GAME_SOUNDSET", true)

    -- Blind nearby criminals
    local blinded = 0
    for _, c in ipairs(criminals) do
        if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested then
            local crim_pos = ENTITY.GET_ENTITY_COORDS(c.ped, true)
            if effect_pos:distance(crim_pos) <= 12.0 then
                NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(c.ped)
                TASK.CLEAR_PED_TASKS_IMMEDIATELY(c.ped)
                TASK.TASK_WANDER_STANDARD(c.ped, 10.0, 10)
                PED.SET_PED_ACCURACY(c.ped, 5)
                blinded = blinded + 1
            end
        end
    end

    radio_message(T("Smoke grenade deployed!") .. " " .. blinded .. " " .. T("blinded"))
    log_event("TACTICAL", "Smoke grenade deployed | Blinded: " .. blinded)

    -- Restore accuracy after smoke clears
    safe_thread("smoke_recovery", function()
        util.yield(8000)
        for _, c in ipairs(criminals) do
            if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested and not ENTITY.IS_ENTITY_DEAD(c.ped) then
                PED.SET_PED_ACCURACY(c.ped, criminal_accuracy)
                TASK.TASK_COMBAT_PED(c.ped, players.user_ped(), 0, 16)
            end
        end
    end)
end

-- ==================== SPEED TRAP ====================

local function toggle_speed_trap()
    if not police_mode then
        log_warning("toggle_speed_trap", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    if speed_trap_active then
        speed_trap_active = false
        remove_blip(speed_trap_blip)
        speed_trap_blip = nil
        speed_trap_pos = nil
        log_event("SPEED_TRAP", "Speed trap deactivated | Fines issued: " .. speed_trap_fines)
        radio_message(T("Speed trap deactivated. Fines issued") .. ": " .. speed_trap_fines)
        if speed_trap_fines > 0 then
            add_rank_points(math.floor(speed_trap_fines / 2))
        end
        speed_trap_fines = 0
    else
        local pos = players.get_position(players.user())
        speed_trap_pos = {x = pos.x, y = pos.y, z = pos.z}
        speed_trap_active = true
        speed_trap_fines = 0

        speed_trap_blip = HUD.ADD_BLIP_FOR_COORD(pos.x, pos.y, pos.z)
        HUD.SET_BLIP_SPRITE(speed_trap_blip, 1)
        HUD.SET_BLIP_COLOUR(speed_trap_blip, 5)
        HUD.SET_BLIP_SCALE(speed_trap_blip, 0.7)
        HUD.SET_BLIP_AS_SHORT_RANGE(speed_trap_blip, true)

        radio_message(T("Speed trap activated! Limit") .. ": " .. math.floor(speed_trap_limit) .. " km/h")
        log_event("SPEED_TRAP", "Speed trap activated | Limit: " .. math.floor(speed_trap_limit) .. " km/h")
    end
end

-- ==================== PRISONER TRANSPORT ====================

local function start_prisoner_transport()
    if not police_mode then
        log_warning("start_prisoner_transport", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    -- Count arrested criminals
    local arrested_count = 0
    for _, c in ipairs(criminals) do
        if c.arrested then
            arrested_count = arrested_count + 1
        end
    end

    if arrested_count == 0 then
        log_event("TRANSPORT", "No prisoners to transport")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No prisoners to transport"))
        return
    end

    -- Spawn transport van
    safe_delete(transport_vehicle)
    local van_hash = util.joaat("policet")
    util.request_model(van_hash)

    local pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())
    local spawn_x = pos.x + math.cos(math.rad(heading)) * 5.0
    local spawn_y = pos.y + math.sin(math.rad(heading)) * 5.0

    transport_vehicle = VEHICLE.CREATE_VEHICLE(van_hash, spawn_x, spawn_y, pos.z + 0.5, heading, true, false, false)
    if transport_vehicle == 0 then
        transport_vehicle = nil
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(van_hash)
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(transport_vehicle, true, true)
    VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(transport_vehicle, 5.0)
    ENTITY.SET_ENTITY_INVINCIBLE(transport_vehicle, true)
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(van_hash)

    transport_prisoners = arrested_count
    transport_active = true

    -- Set random destination (police station area)
    local destinations = {
        {x = 441.1, y = -982.0, z = 30.7},    -- Mission Row PD
        {x = -1108.5, y = -845.0, z = 19.3},  -- Rockford Hills PD
        {x = 826.1, y = -1290.0, z = 28.2},   -- La Mesa PD
        {x = -449.7, y = 6012.0, z = 31.7},   -- Paleto Bay Sheriff
        {x = 1853.0, y = 3686.0, z = 34.3},   -- Sandy Shores Sheriff
    }
    local dest = destinations[math.random(1, #destinations)]
    transport_dest_pos = dest

    remove_blip(transport_dest_blip)
    transport_dest_blip = HUD.ADD_BLIP_FOR_COORD(dest.x, dest.y, dest.z)
    HUD.SET_BLIP_SPRITE(transport_dest_blip, 188)
    HUD.SET_BLIP_COLOUR(transport_dest_blip, 3)
    HUD.SET_BLIP_SCALE(transport_dest_blip, 1.0)
    HUD.SET_BLIP_AS_SHORT_RANGE(transport_dest_blip, false)
    HUD.SET_BLIP_ROUTE(transport_dest_blip, true)
    HUD.SET_BLIP_ROUTE_COLOUR(transport_dest_blip, 3)

    -- Remove arrested criminals from the world
    for i = #criminals, 1, -1 do
        local c = criminals[i]
        if c.arrested then
            safe_delete(c.ped)
            safe_delete(c.vehicle)
            remove_blip(c.blip)
            table.remove(criminals, i)
        end
    end

    log_event("TRANSPORT", "Prisoner transport started with " .. transport_prisoners .. " prisoners")
    radio_message(T("Prisoner transport started!") .. " " .. transport_prisoners .. " " .. T("prisoners. Follow GPS."))
end

local function complete_transport()
    if not transport_active then return end

    local reward = transport_prisoners * 5
    add_rank_points(reward)

    safe_delete(transport_vehicle)
    transport_vehicle = nil
    remove_blip(transport_dest_blip)
    transport_dest_blip = nil
    transport_dest_pos = nil
    transport_active = false

    log_event("TRANSPORT", "Prisoners delivered, reward: " .. reward .. " pts")
    radio_message(T("Prisoners delivered!") .. " +" .. reward .. " " .. T("pts"))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)
    transport_prisoners = 0
end

local function cancel_transport()
    log_event("TRANSPORT", "Prisoner transport cancelled")
    safe_delete(transport_vehicle)
    transport_vehicle = nil
    remove_blip(transport_dest_blip)
    transport_dest_blip = nil
    transport_dest_pos = nil
    transport_active = false
    transport_prisoners = 0
    radio_message(T("Prisoner transport cancelled"))
end

-- ==================== DIFFICULTY SYSTEM ====================

local function apply_difficulty(level)
    if level < 1 or level > #DIFFICULTY_PRESETS then return end
    difficulty_level = level
    local preset = DIFFICULTY_PRESETS[level]
    criminal_accuracy = preset.accuracy
    criminal_health_mult = preset.health
    criminal_flee_chance = preset.flee
    criminal_vehicle_chance = preset.vehicle
    radio_message(T("Difficulty") .. ": " .. T(preset.name))
end

-- ==================== NEW TICK HANDLERS ====================

-- Spike strip tire popping
safe_tick_handler("spike_strips", function()
    if not police_mode or #spike_strips == 0 then return end

    local player_ped = players.user_ped()
    for _, s in ipairs(spike_strips) do
        if s.obj and ENTITY.DOES_ENTITY_EXIST(s.obj) then
            for _, veh in ipairs(entities.get_all_vehicles_as_handles()) do
                if ENTITY.DOES_ENTITY_EXIST(veh) and not PED.IS_PED_IN_VEHICLE(player_ped, veh, false) then
                    local veh_pos = ENTITY.GET_ENTITY_COORDS(veh, true)
                    local dx = veh_pos.x - s.x
                    local dy = veh_pos.y - s.y
                    local dist = math.sqrt(dx * dx + dy * dy)
                    if dist <= spike_radius then
                        local speed = ENTITY.GET_ENTITY_SPEED(veh)
                        if speed > 2.0 then
                            NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(veh)
                            for tire = 0, 7 do
                                VEHICLE.SET_VEHICLE_TYRE_BURST(veh, tire, true, 1000.0)
                            end
                        end
                    end
                end
            end
        end
    end
end)

-- Bounty target tracking
safe_tick_handler("bounty_tracking", function()
    if not police_mode then return end

    for i = #bounty_targets, 1, -1 do
        local b = bounty_targets[i]
        if ENTITY.DOES_ENTITY_EXIST(b.ped) then
            if ENTITY.IS_ENTITY_DEAD(b.ped) and b.alive then
                b.alive = false
                add_rank_points(b.reward)
                remove_blip(b.blip)
                log_event("BOUNTY", "Target eliminated: " .. b.name .. " | Reward: +" .. b.reward)
                radio_message(b.name .. " " .. T("eliminated!") .. " +" .. b.reward .. " " .. T("pts"))
                AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)

                local ped_ref = b.ped
                table.remove(bounty_targets, i)

                safe_thread("bounty_cleanup", function()
                    util.yield(3000)
                    safe_delete(ped_ref)
                end)
            end
        else
            remove_blip(b.blip)
            table.remove(bounty_targets, i)
        end
    end
end)

-- Backup unit cleanup
safe_tick_handler("backup_cleanup", function()
    if not police_mode then return end

    for i = #backup_units, 1, -1 do
        local b = backup_units[i]
        if not ENTITY.DOES_ENTITY_EXIST(b.ped) or ENTITY.IS_ENTITY_DEAD(b.ped) then
            safe_delete(b.ped)
            remove_blip(b.blip)
            table.remove(backup_units, i)
        end
    end
end)

-- Backup units engage criminals
safe_tick_handler("backup_combat", function()
    if not police_mode or #backup_units == 0 then return end

    for _, b in ipairs(backup_units) do
        if ENTITY.DOES_ENTITY_EXIST(b.ped) and not ENTITY.IS_ENTITY_DEAD(b.ped) then
            if PED.GET_SCRIPT_TASK_STATUS(b.ped, 0x2E85A751) == 7 then
                -- Find nearest alive criminal to fight
                local nearest_crim = nil
                local nearest_dist = 999999.0
                local backup_pos = ENTITY.GET_ENTITY_COORDS(b.ped, true)
                for _, c in ipairs(criminals) do
                    if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested and not ENTITY.IS_ENTITY_DEAD(c.ped) then
                        local dist = backup_pos:distance(ENTITY.GET_ENTITY_COORDS(c.ped, true))
                        if dist < nearest_dist then
                            nearest_dist = dist
                            nearest_crim = c.ped
                        end
                    end
                end
                -- Also check bounty targets
                for _, bt in ipairs(bounty_targets) do
                    if ENTITY.DOES_ENTITY_EXIST(bt.ped) and bt.alive and not ENTITY.IS_ENTITY_DEAD(bt.ped) then
                        local dist = backup_pos:distance(ENTITY.GET_ENTITY_COORDS(bt.ped, true))
                        if dist < nearest_dist then
                            nearest_dist = dist
                            nearest_crim = bt.ped
                        end
                    end
                end
                if nearest_crim and nearest_dist < 80.0 then
                    TASK.TASK_COMBAT_PED(b.ped, nearest_crim, 0, 16)
                end
            end
        end
    end
end)

-- SWAT team engage criminals
safe_tick_handler("swat_combat", function()
    if not police_mode or #swat_team == 0 then return end

    for i = #swat_team, 1, -1 do
        local s = swat_team[i]
        if not ENTITY.DOES_ENTITY_EXIST(s.ped) or ENTITY.IS_ENTITY_DEAD(s.ped) then
            safe_delete(s.ped)
            remove_blip(s.blip)
            table.remove(swat_team, i)
        elseif PED.GET_SCRIPT_TASK_STATUS(s.ped, 0x2E85A751) == 7 then
            local nearest_crim = nil
            local nearest_dist = 999999.0
            local swat_pos = ENTITY.GET_ENTITY_COORDS(s.ped, true)
            for _, c in ipairs(criminals) do
                if ENTITY.DOES_ENTITY_EXIST(c.ped) and c.alive and not c.arrested and not ENTITY.IS_ENTITY_DEAD(c.ped) then
                    local dist = swat_pos:distance(ENTITY.GET_ENTITY_COORDS(c.ped, true))
                    if dist < nearest_dist then
                        nearest_dist = dist
                        nearest_crim = c.ped
                    end
                end
            end
            for _, bt in ipairs(bounty_targets) do
                if ENTITY.DOES_ENTITY_EXIST(bt.ped) and bt.alive and not ENTITY.IS_ENTITY_DEAD(bt.ped) then
                    local dist = swat_pos:distance(ENTITY.GET_ENTITY_COORDS(bt.ped, true))
                    if dist < nearest_dist then
                        nearest_dist = dist
                        nearest_crim = bt.ped
                    end
                end
            end
            if nearest_crim and nearest_dist < 100.0 then
                TASK.TASK_COMBAT_PED(s.ped, nearest_crim, 0, 16)
            end
        end
    end
end)

-- Speed trap monitoring
safe_tick_handler("speed_trap", function()
    if not police_mode or not speed_trap_active or not speed_trap_pos then return end

    local trap_v3 = v3(speed_trap_pos.x, speed_trap_pos.y, speed_trap_pos.z)
    local player_ped = players.user_ped()

    for _, veh in ipairs(entities.get_all_vehicles_as_handles()) do
        if ENTITY.DOES_ENTITY_EXIST(veh) and not PED.IS_PED_IN_VEHICLE(player_ped, veh, false) then
            local veh_pos = ENTITY.GET_ENTITY_COORDS(veh, true)
            if trap_v3:distance(veh_pos) <= 30.0 then
                local speed_kmh = ENTITY.GET_ENTITY_SPEED(veh) * 3.6
                if speed_kmh > speed_trap_limit then
                    -- Slow them down
                    local driver = VEHICLE.GET_PED_IN_VEHICLE_SEAT(veh, -1, false)
                    if driver ~= 0 and not PED.IS_PED_A_PLAYER(driver) then
                        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(veh)
                        VEHICLE.SET_VEHICLE_FORWARD_SPEED(veh, speed_trap_limit / 3.6 * 0.5)
                        speed_trap_fines = speed_trap_fines + 1
                        if speed_trap_fines % 3 == 1 then
                            radio_message(T("Speeding detected!") .. " " .. string.format("%.0f", speed_kmh) .. " km/h | " .. T("Total fines") .. ": " .. speed_trap_fines)
                        end
                    end
                end
            end
        end
    end
end)

-- Prisoner transport tracking
safe_tick_handler("transport_tracking", function()
    if not police_mode or not transport_active or not transport_dest_pos then return end

    local player_pos = players.get_position(players.user())
    local dest = transport_dest_pos
    local dist = math.sqrt((player_pos.x - dest.x)^2 + (player_pos.y - dest.y)^2 + (player_pos.z - dest.z)^2)

    if dist <= 20.0 then
        complete_transport()
    end
end)

-- K9 auto-follow when idle
safe_tick_handler("k9_follow", function()
    if not police_mode or not k9_dog or not ENTITY.DOES_ENTITY_EXIST(k9_dog) then return end

    local dog_pos = ENTITY.GET_ENTITY_COORDS(k9_dog, true)
    local player_pos = players.get_position(players.user())
    local dist = player_pos:distance(dog_pos)

    -- Teleport K9 if too far
    if dist > 50.0 then
        local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())
        ENTITY.SET_ENTITY_COORDS(k9_dog, player_pos.x - fwd.x * 2.0, player_pos.y - fwd.y * 2.0, player_pos.z, true, false, false, true)
    end
end)

-- ==================== EMERGENCY CALL SYSTEM ====================

local function start_emergency_call()
    if not police_mode then
        log_warning("start_emergency_call", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if emergency_active then
        log_event("EMERGENCY", "Emergency call attempt while already active")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Emergency already in progress!"))
        return
    end

    local etype = EMERGENCY_TYPES[math.random(1, #EMERGENCY_TYPES)]
    local player_pos = players.get_position(players.user())
    local target_pos = get_random_pos_around(player_pos, 100.0, 300.0)

    emergency_type = etype
    emergency_pos = target_pos
    emergency_timer = os.time()
    emergency_time_limit = etype.time
    emergency_reward = etype.reward
    emergency_active = true

    local num_enemies = math.random(2, 5)
    for i = 1, num_enemies do
        local offset_pos = get_random_pos_around(target_pos, 3.0, 10.0)
        spawn_criminal(offset_pos, etype.armed, false)
    end

    if etype.name == "Hostage Situation" then
        local hostage_hash = util.joaat("a_f_y_business_01")
        util.request_model(hostage_hash)
        emergency_hostage = PED.CREATE_PED(4, hostage_hash, target_pos.x, target_pos.y, target_pos.z, 0.0, true, false)
        if emergency_hostage ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(emergency_hostage, true, true)
            ENTITY.SET_ENTITY_INVINCIBLE(emergency_hostage, true)
            TASK.TASK_COWER(emergency_hostage, -1)
            local hblip = HUD.ADD_BLIP_FOR_ENTITY(emergency_hostage)
            HUD.SET_BLIP_COLOUR(hblip, 2)
            HUD.SET_BLIP_SCALE(hblip, 0.7)
        else
            emergency_hostage = nil
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(hostage_hash)
    end

    remove_blip(emergency_blip)
    emergency_blip = HUD.ADD_BLIP_FOR_COORD(target_pos.x, target_pos.y, target_pos.z)
    HUD.SET_BLIP_SPRITE(emergency_blip, 526)
    HUD.SET_BLIP_COLOUR(emergency_blip, 1)
    HUD.SET_BLIP_SCALE(emergency_blip, 1.2)
    HUD.SET_BLIP_AS_SHORT_RANGE(emergency_blip, false)
    HUD.SET_BLIP_ROUTE(emergency_blip, true)
    HUD.SET_BLIP_ROUTE_COLOUR(emergency_blip, 1)
    HUD.SET_BLIP_FLASHES(emergency_blip, true)
    HUD.SET_BLIP_FLASH_TIMER(emergency_blip, 8000)

    log_event("EMERGENCY", "Emergency call: " .. etype.name .. " | Time limit: " .. etype.time .. "s")
    radio_message(T("EMERGENCY") .. ": " .. T(etype.name) .. "! " .. T("Respond within") .. " " .. etype.time .. "s! " .. T("Reward") .. ": +" .. etype.reward .. " " .. T("pts"))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "TIMER_STOP", "HUD_MINI_GAME_SOUNDSET", true)
end

local function complete_emergency()
    if not emergency_active then return end
    add_rank_points(emergency_reward)
    log_event("EMERGENCY", "Emergency resolved: " .. emergency_type.name .. " | Reward: +" .. emergency_reward)
    radio_message(T("Emergency resolved!") .. " +" .. emergency_reward .. " " .. T("pts"))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)
    safe_delete(emergency_hostage)
    emergency_hostage = nil
    remove_blip(emergency_blip)
    emergency_blip = nil
    emergency_active = false
    emergency_type = nil
    emergency_pos = nil
end

local function fail_emergency()
    if not emergency_active then return end
    log_event("EMERGENCY", "Emergency failed: " .. emergency_type.name .. " | Time expired")
    radio_message(T("Emergency failed!") .. " " .. T("Time expired."))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "CHECKPOINT_MISSED", "HUD_MINI_GAME_SOUNDSET", true)
    safe_delete(emergency_hostage)
    emergency_hostage = nil
    remove_blip(emergency_blip)
    emergency_blip = nil
    emergency_active = false
    emergency_type = nil
    emergency_pos = nil
end

local function cancel_emergency()
    log_event("EMERGENCY", "Emergency call cancelled")
    safe_delete(emergency_hostage)
    emergency_hostage = nil
    remove_blip(emergency_blip)
    emergency_blip = nil
    emergency_active = false
    emergency_type = nil
    emergency_pos = nil
    radio_message(T("Emergency call cancelled"))
end

-- ==================== DUI CHECKPOINT ====================

local function setup_dui_checkpoint()
    if not police_mode then
        log_warning("setup_dui_checkpoint", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if dui_checkpoint_active then
        log_event("DUI", "Checkpoint setup attempt while already active")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Checkpoint already active!"))
        return
    end

    local pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())
    local right_x = -fwd.y
    local right_y = fwd.x

    local base_x = pos.x + fwd.x * 10.0
    local base_y = pos.y + fwd.y * 10.0
    local base_z = pos.z

    local ground = memory.alloc(4)
    if MISC.GET_GROUND_Z_FOR_3D_COORD(base_x, base_y, base_z + 10.0, ground, false, false) then
        base_z = memory.read_float(ground)
    end

    for i = -3, 3 do
        local hash = util.joaat("prop_roadcone01a")
        util.request_model(hash)
        local ox = base_x + right_x * (i * 2.0)
        local oy = base_y + right_y * (i * 2.0)
        local obj = OBJECT.CREATE_OBJECT(hash, ox, oy, base_z, true, false, false)
        if obj ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(obj, true, true)
            place_on_ground(obj)
            ENTITY.FREEZE_ENTITY_POSITION(obj, true)
            table.insert(dui_checkpoint_objects, obj)
        end
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(hash)
    end

    local light_hash = util.joaat("prop_worklight_03b")
    util.request_model(light_hash)
    for i = -1, 1, 2 do
        local ox = base_x + right_x * (i * 5.0)
        local oy = base_y + right_y * (i * 5.0)
        local obj = OBJECT.CREATE_OBJECT(light_hash, ox, oy, base_z, true, false, false)
        if obj ~= 0 then
            ENTITY.SET_ENTITY_AS_MISSION_ENTITY(obj, true, true)
            place_on_ground(obj)
            ENTITY.FREEZE_ENTITY_POSITION(obj, true)
            table.insert(dui_checkpoint_objects, obj)
        end
    end
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(light_hash)

    dui_checkpoint_pos = {x = base_x, y = base_y, z = base_z}
    dui_checkpoint_active = true
    dui_arrests = 0

    dui_checkpoint_blip = HUD.ADD_BLIP_FOR_COORD(base_x, base_y, base_z)
    HUD.SET_BLIP_SPRITE(dui_checkpoint_blip, 1)
    HUD.SET_BLIP_COLOUR(dui_checkpoint_blip, 26)
    HUD.SET_BLIP_SCALE(dui_checkpoint_blip, 0.8)
    HUD.SET_BLIP_AS_SHORT_RANGE(dui_checkpoint_blip, true)

    radio_message(T("DUI checkpoint established"))
    log_event("DUI", "DUI checkpoint established")
end

local function close_dui_checkpoint()
    if not dui_checkpoint_active then return end
    log_event("DUI", "DUI checkpoint closed | Arrests: " .. dui_arrests)
    for _, obj in ipairs(dui_checkpoint_objects) do
        safe_delete(obj)
    end
    dui_checkpoint_objects = {}
    remove_blip(dui_checkpoint_blip)
    dui_checkpoint_blip = nil
    dui_checkpoint_active = false
    if dui_arrests > 0 then
        add_rank_points(dui_arrests * 2)
    end
    radio_message(T("DUI checkpoint closed. Arrests") .. ": " .. dui_arrests)
    dui_arrests = 0
end

local function dui_test_vehicle()
    if not dui_checkpoint_active then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No checkpoint active"))
        return
    end

    local ped = players.user_ped()
    local pos = players.get_position(players.user())
    local best_veh = nil
    local best_dist = 20.0

    for _, veh in ipairs(entities.get_all_vehicles_as_handles()) do
        if ENTITY.DOES_ENTITY_EXIST(veh) and not PED.IS_PED_IN_VEHICLE(ped, veh, false) then
            local veh_pos = ENTITY.GET_ENTITY_COORDS(veh, true)
            local dist = pos:distance(veh_pos)
            if dist <= best_dist and dist > 0 then
                best_dist = dist
                best_veh = veh
            end
        end
    end

    if not best_veh then
        log_event("DUI", "DUI test failed - no vehicle nearby")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No vehicle nearby"))
        return
    end

    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(best_veh)
    util.yield(200)
    VEHICLE.SET_VEHICLE_FORWARD_SPEED(best_veh, 0.0)

    local driver = VEHICLE.GET_PED_IN_VEHICLE_SEAT(best_veh, -1, false)
    if driver ~= 0 and not PED.IS_PED_A_PLAYER(driver) then
        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(driver)
        TASK.CLEAR_PED_TASKS_IMMEDIATELY(driver)
        TASK.TASK_VEHICLE_TEMP_ACTION(driver, best_veh, 1, 8000)

        local is_dui = math.random(1, 100) <= 30
        radio_message(T("Testing driver..."))
        util.yield(2000)

        if is_dui then
            radio_message(T("DUI detected! Arresting driver."))
            TASK.TASK_LEAVE_VEHICLE(driver, best_veh, 0)
            util.yield(2000)
            if ENTITY.DOES_ENTITY_EXIST(driver) and not PED.IS_PED_IN_ANY_VEHICLE(driver, false) then
                TASK.TASK_PLAY_ANIM(driver, "random@arrests@busted", "idle_a", 8.0, -8.0, -1, 1, 0, false, false, false)
                dui_arrests = dui_arrests + 1
                total_arrests = total_arrests + 1
                add_rank_points(2)
                log_event("ARREST", "DUI arrest | Total DUI: " .. dui_arrests)
                AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)
                local driver_ref = driver
                safe_thread("dui_arrest_cleanup", function()
                    util.yield(5000)
                    if ENTITY.DOES_ENTITY_EXIST(driver_ref) then
                        for alpha = 240, 0, -30 do
                            if not ENTITY.DOES_ENTITY_EXIST(driver_ref) then break end
                            ENTITY.SET_ENTITY_ALPHA(driver_ref, alpha, false)
                            util.yield(80)
                        end
                        safe_delete(driver_ref)
                    end
                end)
            end
        else
            log_event("DUI", "Driver tested sober, released")
            radio_message(T("Driver is sober. Released."))
            util.yield(2000)
            if ENTITY.DOES_ENTITY_EXIST(driver) and ENTITY.DOES_ENTITY_EXIST(best_veh) then
                TASK.CLEAR_PED_TASKS_IMMEDIATELY(driver)
                TASK.TASK_VEHICLE_DRIVE_WANDER(driver, best_veh, 20.0, 786603)
            end
        end
    else
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No driver in vehicle"))
    end
end

-- ==================== SUSPECT SEARCH ====================

local function search_suspect()
    if not police_mode then
        log_warning("search_suspect", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    local now = os.time()
    if now - search_cooldown < 5 then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Wait before searching again"))
        return
    end
    search_cooldown = now

    local player_pos = players.get_position(players.user())
    local nearest_ped = nil
    local nearest_dist = 5.0

    for _, ped in ipairs(entities.get_all_peds_as_handles()) do
        if ENTITY.DOES_ENTITY_EXIST(ped) and ped ~= players.user_ped() and not PED.IS_PED_A_PLAYER(ped) then
            local ped_pos = ENTITY.GET_ENTITY_COORDS(ped, true)
            local dist = player_pos:distance(ped_pos)
            if dist < nearest_dist and not ENTITY.IS_ENTITY_DEAD(ped) then
                nearest_dist = dist
                nearest_ped = ped
            end
        end
    end

    if not nearest_ped then
        log_event("SEARCH", "Suspect search failed - no one nearby")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No one nearby to search"))
        return
    end

    NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(nearest_ped)
    util.yield(200)
    TASK.CLEAR_PED_TASKS_IMMEDIATELY(nearest_ped)
    TASK.TASK_HANDS_UP(nearest_ped, 8000, players.user_ped(), -1, false)
    radio_message(T("Searching suspect..."))
    util.yield(3000)

    local has_contraband = math.random(1, 100) <= 25
    local contraband_types = {"drugs", "stolen goods", "illegal weapon", "counterfeit money", "burglary tools"}

    if has_contraband then
        local contraband = contraband_types[math.random(1, #contraband_types)]
        radio_message(T("Contraband found") .. ": " .. T(contraband) .. "! " .. T("Arresting suspect."))
        log_event("ARREST", "Search arrest - found: " .. contraband)
        TASK.CLEAR_PED_TASKS_IMMEDIATELY(nearest_ped)
        TASK.TASK_PLAY_ANIM(nearest_ped, "random@arrests@busted", "idle_a", 8.0, -8.0, -1, 1, 0, false, false, false)
        ENTITY.FREEZE_ENTITY_POSITION(nearest_ped, true)
        total_arrests = total_arrests + 1
        add_rank_points(2)
        AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)
        local ped_ref = nearest_ped
        safe_thread("search_arrest_cleanup", function()
            util.yield(5000)
            if ENTITY.DOES_ENTITY_EXIST(ped_ref) then
                for alpha = 240, 0, -30 do
                    if not ENTITY.DOES_ENTITY_EXIST(ped_ref) then break end
                    ENTITY.SET_ENTITY_ALPHA(ped_ref, alpha, false)
                    util.yield(80)
                end
                safe_delete(ped_ref)
            end
        end)
    else
        log_event("SEARCH", "Nothing found on suspect, released")
        radio_message(T("Nothing found. Suspect released."))
        if ENTITY.DOES_ENTITY_EXIST(nearest_ped) then
            TASK.CLEAR_PED_TASKS_IMMEDIATELY(nearest_ped)
            TASK.TASK_SMART_FLEE_PED(nearest_ped, players.user_ped(), 50.0, 5000, false, false)
        end
    end
end

-- ==================== ESCORT MISSION ====================

local function start_escort_mission()
    if not police_mode then
        log_warning("start_escort_mission", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end
    if escort_active then
        log_event("ESCORT", "Escort attempt while already active")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Escort already in progress!"))
        return
    end

    local pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())

    local vip_veh_hash = util.joaat("cognoscenti")
    local vip_ped_hash = util.joaat("a_m_m_business_01")
    local driver_hash = util.joaat("s_m_m_ciasec_01")
    util.request_model(vip_veh_hash)
    util.request_model(vip_ped_hash)
    util.request_model(driver_hash)

    local spawn_x = pos.x + math.cos(math.rad(heading)) * 8.0
    local spawn_y = pos.y + math.sin(math.rad(heading)) * 8.0

    escort_vehicle = VEHICLE.CREATE_VEHICLE(vip_veh_hash, spawn_x, spawn_y, pos.z + 0.5, heading, true, false, false)
    if escort_vehicle == 0 then
        escort_vehicle = nil
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(vip_veh_hash)
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(vip_ped_hash)
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(driver_hash)
        log_error("start_escort_mission", "Escort vehicle spawn failed")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Escort vehicle spawn failed!"))
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(escort_vehicle, true, true)
    VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(escort_vehicle, 5.0)
    ENTITY.SET_ENTITY_INVINCIBLE(escort_vehicle, false)
    VEHICLE.SET_VEHICLE_ENGINE_ON(escort_vehicle, true, true, true)
    VEHICLE.SET_VEHICLE_CUSTOM_PRIMARY_COLOUR(escort_vehicle, 10, 10, 10)
    VEHICLE.SET_VEHICLE_CUSTOM_SECONDARY_COLOUR(escort_vehicle, 10, 10, 10)
    VEHICLE.SET_VEHICLE_WINDOW_TINT(escort_vehicle, 1)

    local driver = PED.CREATE_PED_INSIDE_VEHICLE(escort_vehicle, 4, driver_hash, -1, true, false)
    if driver ~= 0 then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(driver, true, true)
        ENTITY.SET_ENTITY_INVINCIBLE(driver, true)
        PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(driver, true)
        PED.SET_PED_FLEE_ATTRIBUTES(driver, 0, false)
    end

    escort_vip = PED.CREATE_PED_INSIDE_VEHICLE(escort_vehicle, 4, vip_ped_hash, 0, true, false)
    if escort_vip ~= 0 then
        ENTITY.SET_ENTITY_AS_MISSION_ENTITY(escort_vip, true, true)
        ENTITY.SET_ENTITY_INVINCIBLE(escort_vip, true)
        PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(escort_vip, true)
    else
        escort_vip = nil
    end

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(vip_veh_hash)
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(vip_ped_hash)
    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(driver_hash)

    local destinations = {
        {x = -1037.0, y = -2738.0, z = 20.2},
        {x = -75.0, y = -818.0, z = 326.2},
        {x = -1828.0, y = 798.0, z = 138.2},
        {x = 1155.0, y = -1502.0, z = 34.7},
        {x = -267.0, y = -955.0, z = 31.2},
    }
    local dest = destinations[math.random(1, #destinations)]
    escort_dest_pos = dest

    if driver ~= 0 then
        TASK.TASK_VEHICLE_DRIVE_TO_COORD_LONGRANGE(driver, escort_vehicle, dest.x, dest.y, dest.z, 20.0, 786603, 10.0)
    end

    remove_blip(escort_dest_blip)
    escort_dest_blip = HUD.ADD_BLIP_FOR_COORD(dest.x, dest.y, dest.z)
    HUD.SET_BLIP_SPRITE(escort_dest_blip, 1)
    HUD.SET_BLIP_COLOUR(escort_dest_blip, 2)
    HUD.SET_BLIP_SCALE(escort_dest_blip, 1.0)
    HUD.SET_BLIP_AS_SHORT_RANGE(escort_dest_blip, false)
    HUD.SET_BLIP_ROUTE(escort_dest_blip, true)
    HUD.SET_BLIP_ROUTE_COLOUR(escort_dest_blip, 2)

    local vip_blip = HUD.ADD_BLIP_FOR_ENTITY(escort_vehicle)
    HUD.SET_BLIP_SPRITE(vip_blip, 1)
    HUD.SET_BLIP_COLOUR(vip_blip, 2)
    HUD.SET_BLIP_SCALE(vip_blip, 0.8)

    escort_active = true
    escort_attack_timer = os.time()
    escort_attackers = {}

    log_event("ESCORT", "VIP escort mission started")
    radio_message(T("VIP escort mission! Protect the VIP vehicle and follow to destination."))
end

local function complete_escort()
    if not escort_active then return end
    add_rank_points(10)
    log_event("ESCORT", "VIP safely delivered | Reward: +10")
    radio_message(T("VIP safely delivered!") .. " +10 " .. T("pts"))
    AUDIO.PLAY_SOUND_FRONTEND(-1, "MEDAL_UP", "HUD_MINI_GAME_SOUNDSET", true)

    for _, a in ipairs(escort_attackers) do
        safe_delete(a.ped)
        safe_delete(a.vehicle)
        remove_blip(a.blip)
    end
    escort_attackers = {}
    safe_delete(escort_vip)
    safe_delete(escort_vehicle)
    escort_vip = nil
    escort_vehicle = nil
    remove_blip(escort_dest_blip)
    escort_dest_blip = nil
    escort_dest_pos = nil
    escort_active = false
end

local function cancel_escort()
    log_event("ESCORT", "Escort mission cancelled")
    for _, a in ipairs(escort_attackers) do
        safe_delete(a.ped)
        safe_delete(a.vehicle)
        remove_blip(a.blip)
    end
    escort_attackers = {}
    safe_delete(escort_vip)
    safe_delete(escort_vehicle)
    escort_vip = nil
    escort_vehicle = nil
    remove_blip(escort_dest_blip)
    escort_dest_blip = nil
    escort_dest_pos = nil
    escort_active = false
    radio_message(T("Escort mission cancelled"))
end

-- ==================== POLICE BOAT ====================

local function spawn_police_boat()
    if not police_mode then
        log_warning("spawn_police_boat", "Attempted without being on duty")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Start duty first!"))
        return
    end

    safe_delete(police_boat)
    police_boat = nil

    local boat_hash = util.joaat("predator")
    util.request_model(boat_hash)

    local pos = players.get_position(players.user())
    local heading = ENTITY.GET_ENTITY_HEADING(players.user_ped())
    local fwd = ENTITY.GET_ENTITY_FORWARD_VECTOR(players.user_ped())

    local spawn_x = pos.x + fwd.x * 10.0
    local spawn_y = pos.y + fwd.y * 10.0

    police_boat = VEHICLE.CREATE_VEHICLE(boat_hash, spawn_x, spawn_y, pos.z - 0.5, heading, true, false, false)
    if police_boat == 0 then
        police_boat = nil
        STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(boat_hash)
        log_error("spawn_police_boat", "Boat spawn failed")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Boat spawn failed! Try near water."))
        return
    end

    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(police_boat, true, true)
    ENTITY.SET_ENTITY_INVINCIBLE(police_boat, vehicle_invincible)
    VEHICLE.SET_VEHICLE_ENGINE_ON(police_boat, true, true, true)

    STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(boat_hash)
    log_event("VEHICLE", "Spawned police boat")
    radio_message(T("Police boat deployed"))
end

local function delete_police_boat()
    log_event("VEHICLE", "Police boat removed")
    safe_delete(police_boat)
    police_boat = nil
    radio_message(T("Police boat removed"))
end

local function toggle_siren()
    if not patrol_vehicle or not ENTITY.DOES_ENTITY_EXIST(patrol_vehicle) then
        util.toast("[" .. T("Police Simulator") .. "] " .. T("No patrol vehicle."))
        return
    end

    siren_on = not siren_on
    VEHICLE.SET_VEHICLE_SIREN(patrol_vehicle, siren_on)
    log_event("VEHICLE", "Siren toggled: " .. (siren_on and "ON" or "OFF"))
    util.toast("[" .. T("Police Simulator") .. "] " .. (siren_on and T("Siren ON") or T("Siren OFF")))
end

-- Emergency call timer tick handler
safe_tick_handler("emergency_timer", function()
    if not police_mode or not emergency_active then return end

    local elapsed = os.time() - emergency_timer
    local remaining = emergency_time_limit - elapsed

    if remaining <= 0 then
        fail_emergency()
        return
    end

    if emergency_pos then
        local player_pos = players.get_position(players.user())
        local dist = player_pos:distance(v3(emergency_pos.x, emergency_pos.y, emergency_pos.z))
        if dist < 50.0 then
            local remaining_enemies = 0
            for _, c in ipairs(criminals) do
                if c.alive and not c.arrested and ENTITY.DOES_ENTITY_EXIST(c.ped) and not ENTITY.IS_ENTITY_DEAD(c.ped) then
                    remaining_enemies = remaining_enemies + 1
                end
            end
            if remaining_enemies == 0 then
                complete_emergency()
            end
        end
    end
end)

-- DUI checkpoint vehicle slowdown
safe_tick_handler("dui_checkpoint", function()
    if not police_mode or not dui_checkpoint_active or not dui_checkpoint_pos then return end

    local cp = dui_checkpoint_pos
    local player_ped = players.user_ped()

    for _, veh in ipairs(entities.get_all_vehicles_as_handles()) do
        if ENTITY.DOES_ENTITY_EXIST(veh) and not PED.IS_PED_IN_VEHICLE(player_ped, veh, false) then
            local veh_pos = ENTITY.GET_ENTITY_COORDS(veh, true)
            local dist = math.sqrt((veh_pos.x - cp.x)^2 + (veh_pos.y - cp.y)^2)
            if dist <= 8.0 then
                local speed = ENTITY.GET_ENTITY_SPEED(veh) * 3.6
                if speed > 5.0 then
                    local driver = VEHICLE.GET_PED_IN_VEHICLE_SEAT(veh, -1, false)
                    if driver ~= 0 and not PED.IS_PED_A_PLAYER(driver) then
                        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(veh)
                        VEHICLE.SET_VEHICLE_FORWARD_SPEED(veh, 0.0)
                        NETWORK.NETWORK_REQUEST_CONTROL_OF_ENTITY(driver)
                        TASK.TASK_VEHICLE_TEMP_ACTION(driver, veh, 1, 10000)
                    end
                end
            end
        end
    end
end)

-- Escort mission tracking
safe_tick_handler("escort_tracking", function()
    if not police_mode or not escort_active then return end

    if not escort_vehicle or not ENTITY.DOES_ENTITY_EXIST(escort_vehicle) then
        log_event("ESCORT", "VIP vehicle destroyed - mission failed")
        radio_message(T("VIP vehicle destroyed! Mission failed!"))
        cancel_escort()
        return
    end

    if escort_dest_pos then
        local veh_pos = ENTITY.GET_ENTITY_COORDS(escort_vehicle, true)
        local dist = math.sqrt((veh_pos.x - escort_dest_pos.x)^2 + (veh_pos.y - escort_dest_pos.y)^2)
        if dist <= 25.0 then
            complete_escort()
            return
        end
    end

    local now = os.time()
    if now - escort_attack_timer >= 30 then
        escort_attack_timer = now
        if #escort_attackers < 3 and math.random() > 0.4 then
            local veh_pos = ENTITY.GET_ENTITY_COORDS(escort_vehicle, true)
            local attack_pos = get_random_pos_around(v3(veh_pos.x, veh_pos.y, veh_pos.z), 30.0, 60.0)

            local model = util.joaat(CRIMINAL_MODELS[math.random(1, #CRIMINAL_MODELS)])
            util.request_model(model)
            local att_veh_hash = util.joaat("sultan")
            util.request_model(att_veh_hash)

            local att_veh = VEHICLE.CREATE_VEHICLE(att_veh_hash, attack_pos.x, attack_pos.y, attack_pos.z, 0.0, true, false, false)
            if att_veh ~= 0 then
                ENTITY.SET_ENTITY_AS_MISSION_ENTITY(att_veh, true, true)
                VEHICLE.SET_VEHICLE_ON_GROUND_PROPERLY(att_veh, 5.0)
                local att_ped = PED.CREATE_PED_INSIDE_VEHICLE(att_veh, 4, model, -1, true, false)
                if att_ped ~= 0 then
                    ENTITY.SET_ENTITY_AS_MISSION_ENTITY(att_ped, true, true)
                    WEAPON.GIVE_WEAPON_TO_PED(att_ped, util.joaat("weapon_microsmg"), 300, false, true)
                    PED.SET_PED_FLEE_ATTRIBUTES(att_ped, 0, false)
                    PED.SET_PED_COMBAT_ATTRIBUTES(att_ped, 46, true)
                    PED.SET_PED_COMBAT_ATTRIBUTES(att_ped, 5, true)
                    PED.SET_BLOCKING_OF_NON_TEMPORARY_EVENTS(att_ped, true)
                    PED.SET_PED_ACCURACY(att_ped, 40)
                    PED.SET_PED_AS_ENEMY(att_ped, true)
                    TASK.TASK_VEHICLE_CHASE(att_ped, players.user_ped())
                    TASK.TASK_COMBAT_PED(att_ped, players.user_ped(), 0, 16)

                    local blip = HUD.ADD_BLIP_FOR_ENTITY(att_ped)
                    HUD.SET_BLIP_COLOUR(blip, 1)
                    HUD.SET_BLIP_SCALE(blip, 0.7)
                    table.insert(escort_attackers, {ped = att_ped, vehicle = att_veh, blip = blip})
                    radio_message(T("Hostiles approaching VIP! Protect the convoy!"))
                else
                    safe_delete(att_veh)
                end
            end
            STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(model)
            STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(att_veh_hash)
        end
    end

    for i = #escort_attackers, 1, -1 do
        local a = escort_attackers[i]
        if not ENTITY.DOES_ENTITY_EXIST(a.ped) or ENTITY.IS_ENTITY_DEAD(a.ped) then
            safe_delete(a.ped)
            safe_delete(a.vehicle)
            remove_blip(a.blip)
            table.remove(escort_attackers, i)
            add_rank_points(1)
        end
    end
end)

safe_tick_handler("debug_display", function()
    if not show_debug or not police_mode then return end

    util.draw_debug_text("")
    util.draw_debug_text("[ " .. T("Police Simulator") .. " ]")

    local elapsed = os.time() - shift_start_time
    util.draw_debug_text(T("Duty Time") .. ": " .. string.format("%02d:%02d", math.floor(elapsed / 60), elapsed % 60))
    util.draw_debug_text(T("Rank") .. ": " .. get_rank_name() .. " | " .. T("Points") .. ": " .. rank_points)
    util.draw_debug_text(T("Arrests") .. ": " .. total_arrests .. " | " .. T("Kills") .. ": " .. total_kills)
    util.draw_debug_text(T("Crimes Detected") .. ": " .. total_crimes_detected .. T("cases"))
    if #backup_units > 0 then
        util.draw_debug_text(T("Backup") .. ": " .. #backup_units .. "/" .. max_backup)
    end
    if #bounty_targets > 0 then
        util.draw_debug_text(T("Bounties") .. ": " .. #bounty_targets)
    end
    if #swat_team > 0 then
        util.draw_debug_text(T("SWAT") .. ": " .. #swat_team .. "/" .. max_swat)
    end
    if k9_dog and ENTITY.DOES_ENTITY_EXIST(k9_dog) then
        util.draw_debug_text(T("K9") .. ": " .. T("Active"))
    end
    if speed_trap_active then
        util.draw_debug_text(T("Speed Trap") .. ": " .. T("Active") .. " (" .. speed_trap_fines .. " " .. T("fines") .. ")")
    end
    if transport_active then
        local dest = transport_dest_pos
        local player_pos = players.get_position(players.user())
        local tdist = math.sqrt((player_pos.x - dest.x)^2 + (player_pos.y - dest.y)^2)
        util.draw_debug_text(T("Transport") .. ": " .. transport_prisoners .. " " .. T("prisoners") .. " | " .. string.format("%.0fm", tdist))
    end
    if undercover_mode then
        util.draw_debug_text(T("Undercover") .. ": " .. T("Active"))
    end
    if emergency_active and emergency_type then
        local remaining = emergency_time_limit - (os.time() - emergency_timer)
        util.draw_debug_text(T("Emergency") .. ": " .. T(emergency_type.name) .. " | " .. math.max(0, remaining) .. "s")
    end
    if dui_checkpoint_active then
        util.draw_debug_text(T("DUI Checkpoint") .. ": " .. T("Active") .. " (" .. dui_arrests .. " " .. T("arrests") .. ")")
    end
    if escort_active then
        if escort_vehicle and ENTITY.DOES_ENTITY_EXIST(escort_vehicle) and escort_dest_pos then
            local vpos = ENTITY.GET_ENTITY_COORDS(escort_vehicle, true)
            local edist = math.sqrt((vpos.x - escort_dest_pos.x)^2 + (vpos.y - escort_dest_pos.y)^2)
            util.draw_debug_text(T("Escort") .. ": " .. T("Active") .. " | " .. string.format("%.0fm", edist))
        else
            util.draw_debug_text(T("Escort") .. ": " .. T("Active"))
        end
    end

    local active_count = 0
    for _, c in ipairs(criminals) do
        if c.alive and not c.arrested and ENTITY.DOES_ENTITY_EXIST(c.ped) and not ENTITY.IS_ENTITY_DEAD(c.ped) then
            active_count = active_count + 1
        end
    end
    util.draw_debug_text(T("Active Criminals") .. ": " .. active_count .. " / " .. max_criminals)

    if chase_active and chase_target and ENTITY.DOES_ENTITY_EXIST(chase_target.ped) then
        local player_pos = players.get_position(players.user())
        local crim_pos = ENTITY.GET_ENTITY_COORDS(chase_target.ped, true)
        util.draw_debug_text(T("Chasing! Distance") .. ": " .. string.format("%.0fm", player_pos:distance(crim_pos)))
    end

    if wave_active then
        util.draw_debug_text(T("Wave") .. " " .. wave_number .. " " .. T("Wave in progress"))
    end

    local closest, closest_dist = get_closest_criminal()
    if closest then
        util.draw_debug_text(T("Nearest Criminal") .. ": " .. string.format("%.0fm", closest_dist))
    end

    util.draw_debug_text("")
end)

local ROOT = menu.my_root()
local ref

ref = menu.divider(ROOT, "[ " .. T("Police Simulator") .. " v" .. SCRIPT_VERSION .. " ]")
reg(ref, ROOT, function() return "[ " .. T("Police Simulator") .. " v" .. SCRIPT_VERSION .. " ]" end)

-- Show startup banner
show_banner("log.png", 3.0)
log_init()

local LANG_MENU = menu.list(ROOT, T("Language"), {"pslang"}, T("Select language."))
reg(LANG_MENU, ROOT, function() return T("Language") end, function() return T("Select language.") end)

for _, lf in ipairs(LANG_FILES) do
    menu.action(LANG_MENU, lf.name, {}, "", function()
        if not filesystem.exists(lf.file) then
            util.toast("[" .. T("Police Simulator") .. "] Language file not found: " .. lf.name)
            return
        end
        write_setting("Language", lf.name)
        current_lang = lf.name
        load_language(lf.file)
        refresh_menus()
        log_event("SYSTEM", "Language changed to: " .. lf.name)
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Language") .. ": " .. lf.name)
    end)
end

local DUTY_MENU = menu.list(ROOT, T("Duty"), {"psduty"}, T("Start or end police duty."))
reg(DUTY_MENU, ROOT, function() return T("Duty") end, function() return T("Start or end police duty.") end)

ref = menu.action(DUTY_MENU, T("Start Duty"), {"psstart"}, T("Change into police uniform and receive weapons."), function()
    safe_call("Start Duty", start_police_mode)
end)
reg(ref, DUTY_MENU, function() return T("Start Duty") end, function() return T("Change into police uniform and receive weapons.") end)

ref = menu.action(DUTY_MENU, T("End Duty"), {"psstop"}, T("End police mode and return to original character."), function()
    safe_call("End Duty", stop_police_mode)
end)
reg(ref, DUTY_MENU, function() return T("End Duty") end, function() return T("End police mode and return to original character.") end)

ref = menu.divider(DUTY_MENU, T("Select Uniform"))
reg(ref, DUTY_MENU, function() return T("Select Uniform") end)

for i, model in ipairs(POLICE_MODELS) do
    ref = menu.action(DUTY_MENU, T(model.name), {}, T("Uniform") .. ": " .. T(model.name), function()
        selected_model_idx = i
        log_event("SETTING", "Uniform selected: " .. model.name)
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Uniform selected") .. ": " .. T(model.name))
        if police_mode then
            local hash = util.joaat(model.hash)
            util.request_model(hash)

            local cur_ped = players.user_ped()
            local cur_pos = players.get_position(players.user())
            local cur_heading = ENTITY.GET_ENTITY_HEADING(cur_ped)

            local new_ped = PED.CREATE_PED(4, hash, cur_pos.x, cur_pos.y, cur_pos.z, cur_heading, true, false)
            if new_ped ~= 0 then
                ENTITY.SET_ENTITY_AS_MISSION_ENTITY(new_ped, true, true)
                PED.SET_PED_DEFAULT_COMPONENT_VARIATION(new_ped)
                PED.SET_PED_CONFIG_FLAG(new_ped, 35, false)
                PLAYER.CHANGE_PLAYER_PED(players.user(), new_ped, false, false)
                util.yield(500)

                if cur_ped ~= players.user_ped() and ENTITY.DOES_ENTITY_EXIST(cur_ped) then
                    safe_delete(cur_ped)
                end

                give_police_weapons(players.user_ped())
            end
            STREAMING.SET_MODEL_AS_NO_LONGER_NEEDED(hash)
        end
    end)
    reg(ref, DUTY_MENU, function() return T(model.name) end, function() return T("Uniform") .. ": " .. T(model.name) end)
end

