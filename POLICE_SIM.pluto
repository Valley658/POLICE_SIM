-- POLICE_SIM.pluto

local SCRIPT_VERSION = "1.8.0"

if not util then
    error("This script must be run inside the Stand environment.")
end

util.require_natives(1681379138)
util.keep_running()

local PS_DIR = filesystem.scripts_dir() .. "store\\Police Simulator\\"
local LANG_DIR = PS_DIR .. "Language\\"
local SETTING_DIR = PS_DIR .. "Setting\\"
local SETTING_FILE = SETTING_DIR .. "Setting.txt"
local IMG_DIR = PS_DIR .. "Image\\"
local LOG_DIR = PS_DIR .. "logs\\"
local LOG_FILE = LOG_DIR .. os.date("%Y-%m-%d_%H-%M-%S") .. ".txt"

filesystem.mkdirs(LANG_DIR)
filesystem.mkdirs(SETTING_DIR)
filesystem.mkdirs(IMG_DIR)
filesystem.mkdirs(LOG_DIR)

-- ==================== LOGGING SYSTEM ====================

-- Immediately write to log file (open, write, close per call for reliability)
local function LOG(message)
    local f = io.open(LOG_FILE, "a+")
    if f then
        f:write(os.date("[%m/%d/%Y %I:%M:%S %p]") .. " " .. message .. "\n")
        f:close()
    end
end

local function log_event(category, message)
    LOG("[" .. category .. "] " .. message)
end

local function log_error(source, err_msg)
    LOG("Police Simulator Version: v" .. SCRIPT_VERSION)
    LOG("| ERROR | " .. source .. " | " .. tostring(err_msg))
end

local function log_warning(source, message)
    log_event("WARNING", source .. " | " .. message)
end

-- Fatal error: log + toast + stop script
local function ERROR_LOG(error_message)
    LOG("Police Simulator Version: v" .. SCRIPT_VERSION)
    LOG("| Police Simulator - ERROR | " .. error_message)
    util.toast("[Police Simulator] ERROR\n\n" .. error_message)
    util.stop_script()
end

-- xpcall error handler: writes to log IMMEDIATELY inside the handler
-- This runs BEFORE the stack unwinds, ensuring Stand can't prevent logging
local function make_error_handler(source)
    return function(err)
        local msg = tostring(err)
        local trace = msg
        if debug and debug.traceback then
            trace = debug.traceback(msg, 2)
        end
        -- Write IMMEDIATELY to file inside error handler
        local f = io.open(LOG_FILE, "a+")
        if f then
            f:write(os.date("[%m/%d/%Y %I:%M:%S %p]") .. " Police Simulator Version: v" .. SCRIPT_VERSION .. "\n")
            f:write(os.date("[%m/%d/%Y %I:%M:%S %p]") .. " | ERROR | " .. source .. " | " .. trace .. "\n")
            f:close()
        end
        -- Also output via Stand's toast (shows in-game)
        util.toast("[Police Simulator] Error in " .. source .. ":\n" .. msg)
        -- Also output via Stand's logger (Stand log file + console)
        util.log("[Police Simulator] Error in " .. source .. ": " .. msg)
        return trace
    end
end

local function safe_call(func_name, func, ...)
    local args = {...}
    local ok, result = xpcall(function()
        return func(table.unpack(args))
    end, make_error_handler(func_name))
    if not ok then
        return nil
    end
    return result
end

-- Tick handler wrapper: xpcall catches errors every tick and logs them
local function safe_tick_handler(name, func)
    util.create_tick_handler(function()
        local ok, result = xpcall(func, make_error_handler("tick:" .. name))
        if not ok then
            return false -- stop tick handler on error to prevent spam
        end
        return result -- pass through return value (nil/true = continue, false = stop)
    end)
end

-- Thread wrapper: xpcall catches errors in threads and logs them
local function safe_thread(name, func)
    util.create_thread(function()
        xpcall(func, make_error_handler("thread:" .. name))
    end)
end

-- Safe wrapper for PLACE_ENTITY_ON_GROUND_PROPERLY (check before call)
local function place_on_ground(entity)
    if entity and ENTITY.DOES_ENTITY_EXIST(entity) then
        if ENTITY.PLACE_ENTITY_ON_GROUND_PROPERLY then
            ENTITY.PLACE_ENTITY_ON_GROUND_PROPERLY(entity, true)
        else
            -- Fallback: use ground Z detection
            local pos = ENTITY.GET_ENTITY_COORDS(entity, true)
            local ground = memory.alloc(4)
            if MISC.GET_GROUND_Z_FOR_3D_COORD(pos.x, pos.y, pos.z + 5.0, ground, false, false) then
                local gz = memory.read_float(ground)
                ENTITY.SET_ENTITY_COORDS(entity, pos.x, pos.y, gz, true, false, false, true)
            end
        end
    end
end

local function log_init()
    log_event("SYSTEM", "Police Simulator v" .. SCRIPT_VERSION .. " started")
    log_event("SYSTEM", "Log system initialized")
end

-- Register stop handlers to log script termination
util.on_pre_stop(function()
    LOG("| SYSTEM | Script stop initiated (on_pre_stop)")
end)

util.on_stop(function()
    LOG("| SYSTEM | Police Simulator v" .. SCRIPT_VERSION .. " stopped")
end)

-- ==================== IMAGE / BANNER ====================

local function show_banner(img_name, display_time)
    local img_path = IMG_DIR .. img_name
    if filesystem.exists(img_path) then
        local alpha = 0.0
        local alpha_speed = 0.01
        local img = directx.create_texture(img_path)
        local start_time = os.clock()

        util.create_tick_handler(function()
            alpha = alpha + alpha_speed
            if alpha > 1.0 then
                alpha = 1.0
            elseif alpha < 0.0 then
                alpha = 0.0
                return false
            end
        end)

        util.create_tick_handler(function()
            directx.draw_texture(img, 0.10, 0.10, 0.5, 0.5, 0.5, 0.5, 0.0, 1.0, 1.0, 1.0, alpha)
            local elapsed = os.clock() - start_time
            if elapsed > display_time then
                alpha_speed = -0.015
            end
            if alpha <= 0.0 then
                return false
            end
        end)
    else
        -- Fallback: text-only banner
        local alpha = 0.0
        local alpha_speed = 0.01
        local start_time = os.clock()

        util.create_tick_handler(function()
            alpha = alpha + alpha_speed
            if alpha > 1.0 then
                alpha = 1.0
            elseif alpha < 0.0 then
                alpha = 0.0
                return false
            end
        end)

        util.create_tick_handler(function()
            -- Background
            directx.draw_rect(0.5, 0.42, 0.25, 0.10, 0, 0, 0, alpha * 0.8)
            -- Border
            directx.draw_rect(0.5, 0.375, 0.25, 0.003, 0.2, 0.5, 1.0, alpha)
            directx.draw_rect(0.5, 0.465, 0.25, 0.003, 0.2, 0.5, 1.0, alpha)
            -- Title
            directx.draw_text(0.5, 0.40, T("Police Simulator"), 5, 0.7, {r = 0.3, g = 0.6, b = 1.0, a = alpha}, true)
            -- Version
            directx.draw_text(0.5, 0.44, "v" .. SCRIPT_VERSION, 5, 0.4, {r = 1.0, g = 1.0, b = 1.0, a = alpha * 0.7}, true)

            local elapsed = os.clock() - start_time
            if elapsed > display_time then
                alpha_speed = -0.015
            end
            if alpha <= 0.0 then
                return false
            end
        end)
    end
end

local function scan_lang_files()
    local files = {}
    for _, path in ipairs(filesystem.list_files(LANG_DIR)) do
        if not filesystem.is_dir(path) and path:sub(-4):lower() == ".txt" then
            local fname = path:match("([^\\]+)%.txt$") or path:match("([^/]+)%.txt$")
            if fname then
                local display = fname
                local f = io.open(path, "r")
                if f then
                    local is_first = true
                    for line in f:lines() do
                        if is_first then
                            line = line:gsub("^\xEF\xBB\xBF", "")
                            is_first = false
                        end
                        line = line:match("^%s*(.-)%s*$") or line
                        if line ~= "" and not line:match("^#") and line:match("=") then
                            local k, v = line:match("^(.-)%s*=%s*(.+)$")
                            if k then
                                k = k:match("^%s*(.-)%s*$") or k
                                v = v and (v:match("^%s*(.-)%s*$") or v)
                            end
                            if k == "LANGUAGE_NAME" and v then
                                display = v
                                break
                            end
                        end
                    end
                    f:close()
                end
                table.insert(files, {name = display, file = path})
            end
        end
    end
    return files
end

local LANG_FILES = scan_lang_files()

local function read_setting(key)
    if not filesystem.exists(SETTING_FILE) then return nil end
    local f = io.open(SETTING_FILE, "r")
    if not f then return nil end
    for line in f:lines() do
        local k, v = line:match("^(.-)%s*=%s*(.+)$")
        if k == key then f:close() return v end
    end
    f:close()
end

local function write_setting(key, value)
    local lines = {}
    local found = false
    if filesystem.exists(SETTING_FILE) then
        local f = io.open(SETTING_FILE, "r")
        if f then
            for line in f:lines() do
                local k = line:match("^(.-)%s*=")
                if k and k:match("^%s*(.-)%s*$") == key then
                    table.insert(lines, key .. " = " .. value)
                    found = true
                else
                    table.insert(lines, line)
                end
            end
            f:close()
        end
    end
    if not found then table.insert(lines, key .. " = " .. value) end
    local f = io.open(SETTING_FILE, "w")
    if f then
        for _, line in ipairs(lines) do f:write(line .. "\n") end
        f:close()
    end
end

local Translations = {}

local function load_language(filepath)
    Translations = {}
    if not filesystem.exists(filepath) then return false end
    local f = io.open(filepath, "r")
    if not f then return false end
    local first_line = true
    for line in f:lines() do
        -- UTF-8 BOM 제거
        if first_line then
            line = line:gsub("^\xEF\xBB\xBF", "")
            first_line = false
        end
        -- 앞뒤 공백 제거
        line = line:match("^%s*(.-)%s*$") or line
        if line ~= "" and not line:match("^#") and line:match("=") then
            local key, value = line:match("^(.-)%s*=%s*(.+)$")
            if key and value then
                key = key:match("^%s*(.-)%s*$") or key
                value = value:match("^%s*(.-)%s*$") or value
                Translations[key] = value
            end
        end
    end
    f:close()
    return true
end

function T(key)
    return Translations[key] or key
end

local function find_lang_file(name)
    for _, lf in ipairs(LANG_FILES) do
        if lf.name == name then return lf end
    end
end

local function find_lang_by_prefix(prefix)
    for _, lf in ipairs(LANG_FILES) do
        local fname = lf.file:match("([^\\]+)%.txt$")
        if fname and fname:lower():find(prefix:lower(), 1, true) then return lf end
    end
end

-- Stand 언어 코드 → 언어 파일명 매핑
local STAND_LANG_MAP = {
    ["en"] = "English",
    ["ko"] = "Korean",
    ["zh"] = "Chinese",
    ["ja"] = "Japanese",
    ["jp"] = "Japanese",
    ["fr"] = "French",
    ["de"] = "German",
    ["it"] = "Italian",
    ["es"] = "Spanish",
    ["pt"] = "Portuguese",
    ["ru"] = "Russian",
    ["pl"] = "Polish",
    ["vi"] = "Vietnamese",
}

local current_lang = read_setting("Language")
if not current_lang or current_lang == "Unknown" or not find_lang_file(current_lang) then
    -- Stand 메뉴 언어 기반 자동 감지
    local auto_detected = false
    local stand_lang = nil

    -- 방법 1: lang.get_current()
    local ok1, result1 = pcall(function() return lang.get_current() end)
    if ok1 and result1 then
        stand_lang = result1
    end

    -- 방법 2: menu.get_edition/language (일부 Stand 버전 호환)
    if not stand_lang then
        local ok2, result2 = pcall(function() return menu.get_language and menu.get_language() end)
        if ok2 and result2 then
            stand_lang = result2
        end
    end

    if stand_lang and STAND_LANG_MAP[stand_lang] then
        local lf = find_lang_by_prefix(STAND_LANG_MAP[stand_lang])
        if lf then
            current_lang = lf.name
            write_setting("Language", current_lang)
            auto_detected = true
        end
    end
    if not auto_detected then
        -- OS 로케일 기반 감지 시도
        local ok3, os_lang = pcall(function() return os.setlocale(nil) end)
        if ok3 and os_lang then
            local os_prefix = os_lang:sub(1, 2):lower()
            if STAND_LANG_MAP[os_prefix] then
                local lf = find_lang_by_prefix(STAND_LANG_MAP[os_prefix])
                if lf then
                    current_lang = lf.name
                    write_setting("Language", current_lang)
                    auto_detected = true
                end
            end
        end
    end
    if not auto_detected then
        local lf = find_lang_by_prefix("English")
        if not lf and #LANG_FILES > 0 then lf = LANG_FILES[1] end
        if lf then
            current_lang = lf.name
            write_setting("Language", current_lang)
        end
    end
end

local cur_lf = find_lang_file(current_lang)
if cur_lf then
    load_language(cur_lf.file)
end

local MenuRefs = {}
local refresh_menus

local function reg(ref, parent, name_fn, help_fn)
    table.insert(MenuRefs, {ref = ref, parent = parent, name_fn = name_fn, help_fn = help_fn})
    return ref
end

refresh_menus = function()
    for _, item in ipairs(MenuRefs) do
        if item.name_fn then pcall(menu.set_menu_name, item.ref, item.parent, item.name_fn()) end
        if item.help_fn then pcall(menu.set_help_text, item.ref, item.help_fn()) end
    end
end

