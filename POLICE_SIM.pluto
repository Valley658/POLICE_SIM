ref = menu.action(ROOT, T("Duty Stats"), {"psstats"}, T("Show current duty statistics."), function()
    local elapsed = police_mode and (os.time() - shift_start_time) or 0
    util.toast(
        "[" .. T("Police Simulator") .. "] " .. T("Duty Stats") .. "\n\n" ..
        T("Status") .. ": " .. (police_mode and T("On Duty") or T("Off Duty")) .. "\n" ..
        T("Duty time") .. ": " .. math.floor(elapsed / 60) .. T("min") .. "\n" ..
        T("Arrests") .. ": " .. total_arrests .. T("cases") .. "\n" ..
        T("Kills") .. ": " .. total_kills .. T("cases") .. "\n" ..
        T("Crimes Detected") .. ": " .. total_crimes_detected .. T("cases") .. "\n" ..
        T("Active Criminals") .. ": " .. #criminals .. T("people") .. "\n" ..
        T("Rank") .. ": " .. get_rank_name() .. " (" .. rank_points .. " " .. T("pts") .. ")" .. "\n" ..
        T("Backup") .. ": " .. #backup_units .. "/" .. max_backup .. "\n" ..
        T("Bounties") .. ": " .. #bounty_targets .. "/" .. max_bounties .. "\n" ..
        T("SWAT") .. ": " .. #swat_team .. "/" .. max_swat .. "\n" ..
        T("K9") .. ": " .. (k9_dog and ENTITY.DOES_ENTITY_EXIST(k9_dog) and T("Active") or T("None")) .. "\n" ..
        T("Difficulty") .. ": " .. T(DIFFICULTY_PRESETS[difficulty_level].name) .. "\n" ..
        T("Speed Trap Fines") .. ": " .. speed_trap_fines
    )
end)
reg(ref, ROOT, function() return T("Duty Stats") end, function() return T("Show current duty statistics.") end)

util.on_stop(function()
    log_event("SYSTEM", "Police Simulator stopping")

    -- Auto end duty if still on duty
    if police_mode then
        log_event("SYSTEM", "Auto ending duty on script stop")
        stop_police_mode()
    end

    -- GPS tracking cleanup
    remove_blip(gps_tracking_blip)
    gps_tracking_blip = nil
    gps_tracking_target = nil
    gps_tracking_active = false

    log_event("SYSTEM", "Police Simulator stopped")
end)