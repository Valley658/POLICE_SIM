ref = menu.action(VEHICLE_MENU, T("Delete Patrol Vehicle"), {"psdelete"}, T("Delete current patrol vehicle."), function()
    if patrol_vehicle then
        if PED.IS_PED_IN_VEHICLE(players.user_ped(), patrol_vehicle, false) then
            local pos = players.get_position(players.user())
            TASK.CLEAR_PED_TASKS_IMMEDIATELY(players.user_ped())
            util.yield(100)
            ENTITY.SET_ENTITY_COORDS(players.user_ped(), pos.x + 3, pos.y + 3, pos.z + 0.5, true, false, false, true)
        end
        safe_delete(patrol_partner)
        patrol_partner = nil
        safe_delete(patrol_vehicle)
        patrol_vehicle = nil
        log_event("VEHICLE", "Patrol vehicle deleted")
        util.toast("[" .. T("Police Simulator") .. "] " .. T("Patrol vehicle deleted"))
    end
end)
